<style is:global>
/* Dodatek strony wzgledem wspolnego CSS layoutu:
   1) glif uniwersum inline w wierszu SYMBOL (dl.mech),
   2) pierwsza sekcja bez wymuszonego lamania strony w druku
      (first-of-type layoutu nie matchuje, bo pierwsza sekcja to #skrot). */
.mech .v .glyph-mini{display:inline-block;width:15px;height:15px;margin-right:8px;
  vertical-align:-2px;color:var(--acc)}
.mech .v .glyph-mini svg{display:block;width:100%;height:100%}

/* duza wizualizacja glifu uniwersum - prawa kolumna sec-top */
.uni-vis{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;
  align-self:stretch;margin-top:4px;padding:30px 20px;
  border:1px dashed color-mix(in srgb,var(--acc) 42%,transparent)}
.uni-vis .uv-glyph{width:148px;height:148px;color:var(--acc);
  animation:uv-drift 7s ease-in-out infinite}
.uni-vis .uv-glyph svg{display:block;width:100%;height:100%}
.uni-vis .uv-tag{font-family:var(--mono);font-size:.7rem;letter-spacing:.22em;text-align:center;
  color:color-mix(in srgb,var(--acc) 75%,var(--dim))}
@keyframes uv-drift{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@media (prefers-reduced-motion:reduce){.uni-vis .uv-glyph{animation:none}}
@media (max-width:820px){
  .uni-vis{padding:24px 16px}
  .uni-vis .uv-glyph{width:108px;height:108px}
}

/* karta soundtracku (sektor Expanse): odtwarzacz domyslnie wylaczony, opt-in */
.strack{margin-top:14px;border:1px dashed color-mix(in srgb,var(--acc) 40%,transparent);
  padding:15px 20px}
.strack-row{display:flex;gap:14px;align-items:baseline;flex-wrap:wrap}
.strack-row .k{font-family:var(--disp);font-weight:700;font-size:.78rem;letter-spacing:.2em;color:var(--acc)}
.strack-row p{font-size:.94rem;color:var(--muted);max-width:56ch;margin:0}
.strack-row p b{color:var(--txt)}
.strack-btn{margin-left:auto;font-family:var(--disp);font-weight:700;font-size:.72rem;
  letter-spacing:.18em;color:var(--acc);background:transparent;cursor:pointer;
  border:1px solid color-mix(in srgb,var(--acc) 55%,transparent);padding:8px 14px;
  transition:background .2s,color .2s}
.strack-btn:hover{background:color-mix(in srgb,var(--acc) 18%,transparent)}
.strack-player{margin-top:14px}
.strack-player iframe{display:block;width:100%;max-width:640px;aspect-ratio:16/9;border:0}
@media print{
  #u-ender{break-before:auto}
  .strack{display:none}
}
</style>

<script is:inline>
(() => {
  const btn = document.getElementById('strack-btn');
  const box = document.getElementById('strack-player');
  if (!btn || !box) return;
  btn.addEventListener('click', () => {
    const turnOn = box.hidden;
    if (turnOn) {
      box.innerHTML = '<iframe src="https://www.youtube-nocookie.com/embed/Re105gKtOhs?autoplay=1" title="Footsteps of History - Clinton Shorter" allow="autoplay; encrypted-media" allowfullscreen loading="lazy"></iframe>';
      box.hidden = false;
      btn.textContent = btn.dataset.off || '';
    } else {
      box.innerHTML = '';
      box.hidden = true;
      btn.textContent = btn.dataset.on || '';
    }
    btn.setAttribute('aria-pressed', String(turnOn));
  });
})();
</script>
