---
/**
 * Tresc strony "Motyw sci-fi" (MOTYW SF // SKAD TEN KLIMAT).
 * List milosny do ksiazek, z ktorych wyrosla kosmiczna tozsamosc kampanii:
 * dziesiec uniwersow, kazde z kolorem, glifem i powodem (universes.ts).
 * hud-top/footer/CSS/JS przejmuje TenxCosmicLayout.
 * i18n: teksty w i18n/kanon.ts (pl+en), markup i SVG wspolne;
 * zmiana tresci = zmiana obu jezykow w slowniku.
 */
import type { Lang } from '../i18n';
import { KANON } from '../i18n/kanon';
import { UNIVERSES, universeName, type UniverseId } from '../universes';
import { pageHref } from '../pages';

interface Props {
  base: string;
  lang?: Lang;
}

const { base, lang = 'pl' } = Astro.props;
const t = KANON[lang];

/** Kolejnosc kanonu: kolejnosc chipow, kart skrotu i sekcji. */
const ORDER: UniverseId[] = [
  'ender',
  'trzycia',
  'hyperion',
  'diuna',
  'wh40k',
  'expanse',
  'starwars',
  'fundacja',
  'lem',
  'redrising',
];

/** Wezly konstelacji w SVG hero: pozycja glifu + linia do wezla 10x. */
const NODES: { id: UniverseId; x: number; y: number; link: string }[] = [
  { id: 'ender', x: 110, y: 48, link: 'M134,58 L440,106' },
  { id: 'trzycia', x: 295, y: 48, link: 'M307,68 L456,100' },
  { id: 'hyperion', x: 480, y: 48, link: 'M480,72 L480,100' },
  { id: 'diuna', x: 665, y: 48, link: 'M653,68 L504,100' },
  { id: 'wh40k', x: 850, y: 48, link: 'M826,58 L520,106' },
  { id: 'expanse', x: 110, y: 206, link: 'M134,196 L440,154' },
  { id: 'starwars', x: 295, y: 206, link: 'M307,188 L456,160' },
  { id: 'fundacja', x: 480, y: 206, link: 'M480,184 L480,160' },
  { id: 'lem', x: 665, y: 206, link: 'M653,188 L504,160' },
  { id: 'redrising', x: 850, y: 206, link: 'M826,196 L520,154' },
];

/** Glif uniwersum osadzony w duzym SVG (zagniezdzony <svg> z pozycja i rozmiarem). */
const glyphAt = (id: UniverseId, x: number, y: number, s = 34) =>
  UNIVERSES[id].glyph.replace('<svg ', `<svg x="${x}" y="${y}" width="${s}" height="${s}" `);

/** Duza wizualizacja glifu uniwersum - prawa kolumna sec-top (dekoracja; opis niesie wiersz SYMBOL). */
const uniVis = (id: UniverseId) => `
  <div class="uni-vis" aria-hidden="true">
    <div class="uv-glyph">${UNIVERSES[id].glyph}</div>
    <span class="uv-tag">${t.sigil[id]}</span>
  </div>`;
---

<header>
  <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-star" aria-hidden="true"></span>{t.eyebrow}</p>
  <h1 set:html={t.h1Html} />
  <p class="sub" set:html={t.subHtml} />

  <div class="chainwrap">
    <svg class="chain" viewBox="0 0 960 260" role="img" aria-label={t.svgAria}>
      <ellipse cx="480" cy="130" rx="340" ry="88" fill="none" stroke="#7c8cff" opacity=".18" stroke-dasharray="4 6"/>
      {NODES.map((n) => (
        <path d={n.link} stroke={UNIVERSES[n.id].color} fill="none" stroke-dasharray="4 5" opacity=".3" class="anim-dash"/>
      ))}
      <g style="color:var(--indigo)">
        <rect class="kbox" x="428" y="102" width="104" height="56" stroke-width="1.4"/>
        <text class="knum" x="480" y="124" text-anchor="middle">{t.svgTheme}</text>
        <text class="klbl" x="480" y="146" text-anchor="middle">{t.svgThemeSub}</text>
      </g>
      {NODES.map((n) => (
        <a href={`#u-${n.id}`} style={`color:${UNIVERSES[n.id].color}`} aria-label={t.nodeAria(universeName(UNIVERSES[n.id], lang))}>
          <rect x={n.x - 55} y={n.y < 130 ? 14 : 176} width="110" height="84" fill="transparent"/>
          <Fragment set:html={glyphAt(n.id, n.x - 17, n.y - 17)} />
          <text x={n.x} y={n.y < 130 ? 90 : 244} text-anchor="middle">{t.short[n.id].toUpperCase()}</text>
        </a>
      ))}
      <circle r="7" fill="#7c8cff" opacity=".25"><animateMotion dur="14s" repeatCount="indefinite" path="M140,130 a340,88 0 1,0 680,0 a340,88 0 1,0 -680,0"/></circle>
      <circle r="3" fill="#dce2f5" class="anim-pulse"><animateMotion dur="14s" repeatCount="indefinite" path="M140,130 a340,88 0 1,0 680,0 a340,88 0 1,0 -680,0"/></circle>
    </svg>
    <p class="map-cap">{t.mapCap}</p>
  </div>

  <nav class="route" aria-label={t.routeAria}>
    {ORDER.map((id) => (
      <a href={`#u-${id}`} style={`--hov:${UNIVERSES[id].color}`}>{t.short[id]}</a>
    ))}
    <a href="#dalej">{t.routeNext}</a>
  </nav>
</header>

<!-- ============ SKRÓT ============ -->
<section id="skrot">
  <div class="rv">
    <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-star" aria-hidden="true"></span>{t.sumEyebrow}</p>
  </div>
  <div class="sum-grid rv">
    {ORDER.map((id, i) => (
      <a class="sum-card" href={`#u-${id}`} style={`--acc:${UNIVERSES[id].color}`}>
        <Fragment set:html={UNIVERSES[id].glyph} />
        <span class="num">SF-{String(i + 1).padStart(2, '0')}</span>
        <h3>{universeName(UNIVERSES[id], lang)}</h3>
        <p>{t.hook[id]}</p>
      </a>
    ))}
  </div>
  <div class="epigraph finis rv" style="--acc:var(--indigo)">
    <p>{t.epigraph}</p>
    <cite>{t.epigraphCite}</cite>
  </div>
</section>

<!-- ============ ENDER ============ -->
<section class="sector" id="u-ender" style={`--acc:${UNIVERSES.ender.color}`}>
  <div class="sec-top rv">
  <div>
    <div class="sec-head">
      <span class="sec-num">{t.u.ender.num}</span>
      <span class="sec-uni"><Fragment set:html={UNIVERSES.ender.glyph} />{t.u.ender.why}</span>
    </div>
    <h2>{t.u.ender.h2}</h2>
    <p class="lead" style="margin-top:22px" set:html={t.u.ender.pHtml[0]} />
    <p class="lead" style="margin-top:14px" set:html={t.u.ender.pHtml[1]} />
  </div>
  <Fragment set:html={uniVis('ender')} />
  </div>
  <div class="rv">
    <dl class="mech">
      <div><dt><span class="ico ico-star" aria-hidden="true"></span>{t.mech.rating}</dt><dd class="v" style="margin:0" set:html={t.u.ender.ratingHtml} /></div>
      <div><dt><span class="ico ico-eye" aria-hidden="true"></span>{t.mech.screen}</dt><dd class="v" style="margin:0" set:html={t.u.ender.screenHtml} /></div>
      <div><dt><span class="ico ico-cube" aria-hidden="true"></span>{t.mech.symbol}</dt><dd class="v" style="margin:0"><span class="glyph-mini" aria-hidden="true"><Fragment set:html={UNIVERSES.ender.glyph} /></span>{t.u.ender.symbol}</dd></div>
      <div><dt><span class="ico ico-link" aria-hidden="true"></span>{t.mech.links}</dt><dd class="v" style="margin:0"><a href={`${pageHref(base, 'csc', lang)}#k-new`} style="color:var(--acc)">{t.u.ender.links[0]}</a> · <a href={`${pageHref(base, 'fundament', lang)}#l-04`} style="color:var(--acc)">{t.u.ender.links[1]}</a> · <a href={`${pageHref(base, 'teamwork', lang)}#t-02`} style="color:var(--acc)">{t.u.ender.links[2]}</a></dd></div>
    </dl>
  </div>
  <div class="target rv">
    <span class="k"><span class="ico ico-aim" aria-hidden="true"></span>{t.targetK}</span>
    <p set:html={t.u.ender.targetHtml} />
  </div>
</section>

