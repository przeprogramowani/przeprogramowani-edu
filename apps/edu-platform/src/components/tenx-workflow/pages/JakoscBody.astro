---
/**
 * Tresc strony "Modul 3: Jakosc" (plan testow, wyrocznia, hooki, E2E, debug).
 * Zrodlo: kampania 10xdevs-jakosc.html; hud-top/footer/CSS/JS przejmuje
 * TenxCosmicLayout. Kolory sekcji wg kanonu uniwersow (universes.ts).
 * i18n: teksty w i18n/jakosc.ts (pl+en), markup i SVG wspolne;
 * zmiana tresci = zmiana obu jezykow w slowniku.
 */
import { lessonUrl } from '../config';
import type { Lang } from '../i18n';
import { JAKOSC } from '../i18n/jakosc';
import { pageHref } from '../pages';
import { UNIVERSES } from '../universes';
import DeepDive from '../DeepDive.astro';

interface Props {
  base: string;
  lang?: Lang;
