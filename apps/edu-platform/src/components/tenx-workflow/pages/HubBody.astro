---
/**
 * Tresc strony glownej portalu (MOSTEK // WIDOK GLOWNY) - hub w duchu
 * mostka Rocinante (The Expanse): konsola operacyjna, w ktorej kazdy panel
 * to jedna KATEGORIA portalu (Kurs, Moduly, Skille, Ekosystem, FAQ). Kazdy
 * panel prowadzi do strony domowej kategorii (Przegald z indeksem podstron).
 * W trybie neutralnym czyta sie jako panel sterowania portalu, bez nazw statkow.
 *
 * Konsola jest kontekstowa: liczba kafli = kategorie widoczne dla widza
 * (prop `pages`). Publicznie (10xdevs-4) jest ich piec; w kontekscie gated FAQ
 * i strony marketingowe znikaja, wiec kafli jest mniej. Uklad SVG liczy sie
 * z liczby kategorii, wiec dziala dla obu kontekstow.
 *
 * Kolory kafli i zajawki: CATEGORY_META + CATEGORIES (i18n/categories.ts);
 * etykiety kategorii z NAV_CATEGORY_LABEL. hud-top, xnav, footer i wspolny CSS
 * renderuje TenxCosmicLayout. Pozostale teksty (naglowek, "jak czytac",
 * geneza, dalej) w i18n/hub.ts (pl+en).
 */
import type { Lang } from '../i18n';
import { CATEGORIES, CATEGORY_META } from '../i18n/categories';
import { HUB } from '../i18n/hub';
import {
  NAV_CATEGORY_LABEL,
  NAV_CATEGORY_ORDER,
  WORKFLOW_PAGES,
  categoryHomePage,
  categoryMembers,
  pageHref,
  type NavCategoryId,
  type WorkflowPage,
} from '../pages';
import { SKILL_PAGES } from '../skills';
import { UNIVERSES, universeName } from '../universes';

interface Props {
  base: string;
  lang?: Lang;
  /** Strony widoczne dla widza (gated/public) - decyduja, ile kafli kategorii. */
  pages?: WorkflowPage[];
}

const { base, lang = 'pl', pages = WORKFLOW_PAGES } = Astro.props;
const t = HUB[lang];

/** Kafel kategorii: link do strony domowej (Przegald) danej kategorii. */
interface Cat {
  id: NavCategoryId;
  href: string;
  label: string;
  accent: string;
  glyph: string;
  num: string;
  tileP: string;
  aria: string;
}

// Kategoria trafia na mostek, gdy ma strone domowa (Przegald) albo dokladnie
// jedna podstrone (FAQ) - i realnie ma co pokazac w kontekscie widza. Skille
// nie maja stron w rejestrze (ich podstrony to SKILL_PAGES), wiec licza sie
// osobno i tylko gdy dostepna jest strona csc (kontekst skilli).
const cscVisible = pages.some((p) => p.slug === 'csc');
const cats: Cat[] = NAV_CATEGORY_ORDER.map((id) => {
  const home = categoryHomePage(id, pages);
  const members = categoryMembers(id, pages);
  const memberCount = id === 'skille' ? (cscVisible ? SKILL_PAGES.length : 0) : members.length;
  const href = home
    ? pageHref(base, home.slug, lang)
    : memberCount === 1
      ? members[0].href ?? pageHref(base, members[0].slug, lang)
      : null;
  const label = NAV_CATEGORY_LABEL[lang][id];
  const meta = CATEGORY_META[id];
  const tileP = CATEGORIES[lang][id].tileP;
  return href && memberCount > 0
    ? { id, href, label, accent: meta.accent, glyph: meta.glyph, num: meta.num, tileP, aria: `${label} - ${tileP}` }
    : null;
}).filter((c): c is Cat => c !== null);

const N = cats.length;

// ---------- konsola pozioma (desktop) ----------
// Panele w jednym rzedzie, wysrodkowane; ekran centralny pod nimi. Wspolrzedne
// licza sie z N, wiec uklad dziala dla 4 i 5 kategorii.
const PW = 150;
const PH = 64;
const PY = 24;
const GAP = 42;
const totalW = N * PW + (N - 1) * GAP;
const startX = Math.round((960 - totalW) / 2);
const dPanels = cats.map((c, i) => {
  const x = startX + i * (PW + GAP);
  const cx = x + PW / 2;
  // punkt na gornej krawedzi ekranu (344..616), rownomiernie po szerokosci
  const targetX = N === 1 ? 480 : Math.round(344 + (i * 272) / (N - 1));
  return { ...c, x, cx, numY: PY + 22, lblY: PY + 46, dotX: x + PW - 13, dotY: PY + 13, targetX };
});

// ---------- konsola pionowa (mobile, <=720px) ----------
// Ekran centralny u gory, panele w dwoch kolumnach pod nim - zero scrolla poziomego.
const MW = 200;
const MH = 72;
const mPanels = cats.map((c, i) => {
  const col = i % 2;
  const row = Math.floor(i / 2);
  const x = col === 0 ? 20 : 260;
  const y = 160 + row * 98;
  const cx = x + MW / 2;
  return {
    ...c,
    x,
    y,
    cx,
    numY: y + 26,
    lblY: y + 52,
    dotX: x + MW - 13,
    dotY: y + 13,
    flow: `M${cx},${row === 0 ? 124 : y - 26} V${y}`,
  };
});
const mViewH = 160 + Math.ceil(N / 2) * 98 + 20;
---

<style is:global>
/* Reguly specyficzne dla strony (diff vs CSS wspolny w TenxCosmicLayout) */
@media print{
  #skrot{break-before:auto}
}
header h1 .glow{color:#3ddad0;text-shadow:0 0 24px rgba(61,218,208,.45)}
/* hub: na <=720px pozioma konsola ustepuje wariantowi pionowemu (bez scrolla
   poziomego); klasy chain-d / chain-m istnieja tylko na tej stronie, wiec
   reguly nie dotykaja diagramow innych stron. */
svg.chain-m{display:none}
@media(max-width:720px){
  svg.chain-d{display:none}
  svg.chain-m{display:block;min-width:0}
}
</style>

<header>
  <p class="eyebrow" style="--acc:#3ddad0"><span class="ico ico-radar" aria-hidden="true"></span>{t.eyebrow}</p>
  <h1><span class="sf-only" set:html={t.h1SfHtml} /><span class="neutral-only" set:html={t.h1NeutralHtml} /></h1>
  <p class="sub" set:html={t.subHtml} />

  <div class="chainwrap">
    <svg class="chain chain-d" viewBox="0 0 960 250" role="img" aria-label={t.svgDesktopAria}>
      <!-- rama pulpitu -->
      <rect x="8" y="8" width="944" height="234" fill="none" stroke="#3ddad0" opacity=".22"/>
      <g stroke="#3ddad0" fill="none" opacity=".55">
        <path d="M8,26 V8 H26 M934,8 H952 V26 M952,224 V242 H934 M26,242 H8 V224"/>
      </g>
      <!-- gwiazdy w przerwach pulpitu -->
      <g fill="#8a93b8" opacity=".35">
        <circle cx="40" cy="120" r="1.2"/><circle cx="150" cy="176" r="1"/><circle cx="252" cy="118" r="1.3"/>
        <circle cx="708" cy="118" r="1"/><circle cx="820" cy="176" r="1.4"/><circle cx="918" cy="126" r="1"/>
      </g>
      <!-- przeplywy danych: panele -> ekran centralny -->
      {dPanels.map((p) => (
        <path d={`M${p.cx},88 L${p.targetX},138`} stroke={p.accent} fill="none" stroke-dasharray="4 5" opacity=".3" class="anim-dash"/>
      ))}
      <!-- ekran centralny -->
      <g style="color:#3ddad0">
        <rect class="kbox" x="330" y="138" width="300" height="84" stroke-width="1.5"/>
        <text class="klbl" x="480" y="172" text-anchor="middle">{t.screenTitle}</text>
        <text class="knum sf-only" x="480" y="196" text-anchor="middle">{t.screenSf}</text>
        <text class="knum neutral-only" x="480" y="196" text-anchor="middle">{t.screenNeutral}</text>
        <path d="M344,206 H616" stroke="currentColor" stroke-dasharray="6 8" opacity=".3" class="anim-dash-slow" fill="none"/>
        <circle cx="344" cy="151" r="2.4" fill="currentColor" class="anim-pulse"/>
        <circle cx="356" cy="151" r="2.4" fill="currentColor" opacity=".5" class="anim-pulse" style="animation-delay:-.6s"/>
        <circle cx="368" cy="151" r="2.4" fill="currentColor" opacity=".3" class="anim-pulse" style="animation-delay:-1.2s"/>
      </g>
      <!-- panele-wskazniki (kategorie) -->
      {dPanels.map((p) => (
        <a href={p.href} style={`color:${p.accent}`} aria-label={p.aria}>
          <rect class="kbox" x={p.x} y={PY} width={PW} height={PH} stroke-width="1.4"/>
          <text class="knum" x={p.cx} y={p.numY} text-anchor="middle">{p.num}</text>
          <text class="klbl" x={p.cx} y={p.lblY} text-anchor="middle">{p.label.toUpperCase()}</text>
          <circle cx={p.dotX} cy={p.dotY} r="3" fill="currentColor" class="anim-pulse"/>
        </a>
      ))}
      <!-- iskra: obieg ekranu -->
      <circle r="7" fill="#3ddad0" opacity=".25"><animateMotion dur="9s" repeatCount="indefinite" path="M330,138 H630 V222 H330 Z"/></circle>
      <circle r="3" fill="#dce2f5" class="anim-pulse"><animateMotion dur="9s" repeatCount="indefinite" path="M330,138 H630 V222 H330 Z"/></circle>
    </svg>
    <!-- wariant pionowy konsoli (tylko <=720px) -->
    <svg class="chain chain-m" viewBox={`0 0 480 ${mViewH}`} role="img" aria-label={t.svgMobileAria}>
      <!-- rama pulpitu -->
      <rect x="8" y="8" width="464" height={mViewH - 16} fill="none" stroke="#3ddad0" opacity=".22"/>
      <!-- przeplywy danych: ekran centralny -> panele (pionowa kaskada) -->
      {mPanels.map((p) => (
        <path d={p.flow} stroke={p.accent} fill="none" stroke-dasharray="4 5" opacity=".3" class="anim-dash"/>
      ))}
      <!-- ekran centralny -->
      <g style="color:#3ddad0">
        <rect class="kbox" x="90" y="40" width="300" height="84" stroke-width="1.5"/>
        <text class="klbl" x="240" y="74" text-anchor="middle">{t.screenTitle}</text>
        <text class="knum sf-only" x="240" y="98" text-anchor="middle">{t.screenSf}</text>
        <text class="knum neutral-only" x="240" y="98" text-anchor="middle">{t.screenNeutral}</text>
        <path d="M104,108 H376" stroke="currentColor" stroke-dasharray="6 8" opacity=".3" class="anim-dash-slow" fill="none"/>
      </g>
      <!-- panele-wskazniki (kategorie) -->
      {mPanels.map((p) => (
        <a href={p.href} style={`color:${p.accent}`} aria-label={p.aria}>
          <rect class="kbox" x={p.x} y={p.y} width={MW} height={MH} stroke-width="1.4"/>
          <text class="knum" x={p.cx} y={p.numY} text-anchor="middle">{p.num}</text>
          <text class="klbl" x={p.cx} y={p.lblY} text-anchor="middle">{p.label.toUpperCase()}</text>
          <circle cx={p.dotX} cy={p.dotY} r="3" fill="currentColor" class="anim-pulse"/>
        </a>
      ))}
    </svg>
    <p class="map-cap"><span class="sf-only">{t.mapCapSf}</span><span class="neutral-only">{t.mapCapNeutral}</span></p>
  </div>

  <nav class="route" aria-label={t.routeAria}>
    <a href="#skrot" style="--hov:#3ddad0">{t.routeSkrot}</a>
    <a href="#jak-czytac" style="--hov:#3ddad0">{t.routeJak}</a>
    <a class="sf-only" href="#geneza" style="--hov:var(--indigo)">{t.routeGeneza}</a>
    <a href="#dalej">{t.routeDalej}</a>
  </nav>
</header>

<!-- ============ SKRÓT / KATEGORIE ============ -->
<section id="skrot">
  <div class="rv">
    <p class="eyebrow" style="--acc:#3ddad0"><span class="ico ico-star" aria-hidden="true"></span>{t.skrotEyebrow}</p>
  </div>
  <div class="sum-grid rv">
    {cats.map((c) => (
      <a class="sum-card" href={c.href} style={`--acc:${c.accent}`} aria-label={c.aria}>
        <Fragment set:html={c.glyph} />
        <span class="num">{c.num}</span>
        <h3>{c.label}</h3>
        <p>{c.tileP}</p>
      </a>
    ))}
  </div>
</section>

<!-- ============ JAK CZYTAĆ TEN PORTAL ============ -->
<section class="sector" id="jak-czytac" style="--acc:#3ddad0">
  <div class="rv">
    <div class="sec-head">
      <span class="sec-num">{t.how.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.expanse.glyph} />{universeName(UNIVERSES.expanse, lang)}{t.how.uniSuffix}</span>
    </div>
    <h2>{t.how.h2}</h2>
  </div>
  <div class="solo rv">
    <p class="lead">{t.how.lead}</p>
  </div>
  <div class="rv">
    <dl class="mech">
      <div><dt><span class="ico ico-eye" aria-hidden="true"></span>{t.how.modeDt}</dt><dd class="v" style="margin:0" set:html={t.how.modeDdHtml} /></div>
      <div><dt><span class="ico ico-lens" aria-hidden="true"></span>{t.how.ddDt}</dt><dd class="v" style="margin:0" set:html={t.how.ddDdHtml} /></div>
      <div><dt><span class="ico ico-cli" aria-hidden="true"></span>{t.how.skillsDt}</dt><dd class="v" style="margin:0">{t.how.skillsPre}<a href={pageHref(base, 'csc', lang)} style="color:var(--acc)">{t.how.skillsLink}</a>{t.how.skillsRest}</dd></div>
      <div><dt><span class="ico ico-doc" aria-hidden="true"></span>{t.how.searchDt}</dt><dd class="v" style="margin:0"><Fragment set:html={t.how.searchPreHtml} /><a href={pageHref(base, 'docs', lang)} style="color:var(--acc)">{t.how.searchLink}</a><Fragment set:html={t.how.searchRestHtml} /></dd></div>
    </dl>
  </div>
</section>

<!-- ============ SKĄD TO SIĘ WZIĘŁO (SF) ============ -->
<section class="sector sf-only" id="geneza" style="--acc:var(--indigo)">
  <div class="rv">
    <div class="sec-head">
      <span class="sec-num">{t.geneza.num}</span>
      <span class="sec-uni"><span class="ico ico-star" aria-hidden="true"></span>{t.geneza.uni}</span>
    </div>
    <h2>{t.geneza.h2}</h2>
  </div>
  <div class="solo rv">
    <p class="lead">{t.geneza.leadPre}<a href={pageHref(base, 'kanon', lang)} style="color:var(--acc)">{t.geneza.leadLink1}</a>{t.geneza.leadMid}<a href={pageHref(base, 'top5', lang)} style="color:var(--acc)">{t.geneza.leadLink2}</a>{t.geneza.leadPost}</p>
  </div>
</section>

<!-- ============ DALEJ ============ -->
<section class="sector" id="dalej" style="--acc:#3ddad0">
  <div class="rv">
    <div class="sec-head">
      <span class="sec-num"><span class="sf-only">{t.dalej.numSf}</span><span class="neutral-only">{t.dalej.numNeutral}</span></span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.expanse.glyph} />{t.dalej.uni}</span>
    </div>
    <h2>{t.dalej.h2Pre}<span style={`color:${UNIVERSES.hyperion.color};text-shadow:0 0 24px color-mix(in srgb,${UNIVERSES.hyperion.color} 45%,transparent)`}>{t.dalej.h2Accent}</span></h2>
  </div>
  <div class="target rv" style={`--acc:${UNIVERSES.hyperion.color}`}>
    <span class="k"><span class="ico ico-aim" aria-hidden="true"></span>{t.dalej.targetK}</span>
    <p>{t.dalej.targetPre}<a href={pageHref(base, 'top5', lang)} style={`color:${UNIVERSES.hyperion.color}`}><b>{t.dalej.targetLink}</b></a>{t.dalej.targetRest}</p>
  </div>
  <div class="solo rv">
    <div class="tx">
      <span class="mono"><span class="ico ico-link" aria-hidden="true"></span>{t.dalej.mono}</span>
      <dl class="mech">
        <div><dt><span class="ico ico-aim" aria-hidden="true"></span>{t.dalej.top5Dt}</dt><dd class="v" style="margin:0"><a href={pageHref(base, 'top5', lang)} style={`color:${UNIVERSES.hyperion.color}`}>{t.dalej.top5Link}</a>{t.dalej.top5Rest}</dd></div>
        <div><dt><span class="ico ico-fast" aria-hidden="true"></span>{t.dalej.coreDt}</dt><dd class="v" style="margin:0"><a href={pageHref(base, 'csc', lang)} style="color:var(--acc)">{t.dalej.coreLink}</a>{t.dalej.coreRest}</dd></div>
        <div><dt><span class="ico ico-cube" aria-hidden="true"></span>{t.dalej.startDt}</dt><dd class="v" style="margin:0"><a href={pageHref(base, 'fundament', lang)} style="color:var(--acc)">{t.dalej.startLink}</a>{t.dalej.startRest}</dd></div>
        <div><dt><span class="ico ico-doc" aria-hidden="true"></span>{t.dalej.docsDt}</dt><dd class="v" style="margin:0"><a href={pageHref(base, 'docs', lang)} style="color:var(--acc)">{t.dalej.docsLink}</a>{t.dalej.docsRest}</dd></div>
      </dl>
    </div>
  </div>
  <div class="epigraph finis rv" style="--acc:#3ddad0">
    <p>{t.dalej.finis}</p>
    <cite>- <span class="sf-only">{t.dalej.finisCiteSf}</span><span class="neutral-only">{t.dalej.finisCiteNeutral}</span></cite>
  </div>
</section>
