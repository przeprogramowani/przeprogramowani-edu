---
/**
 * Tresc strony "Modul 4: Legacy" (10x Workflow).
 * Transplant <body> z kampanii 10xdevs-legacy.html; kolory sekcji
 * przefarbowane na kanon uniwersow (universes.ts), linki miedzy stronami
 * przez pageHref, glify uniwersow w sec-uni.
 * i18n: teksty w i18n/legacy.ts (pl+en), markup i SVG wspolne;
 * zmiana tresci = zmiana obu jezykow w slowniku.
 */
import { lessonUrl } from '../config';
import type { Lang } from '../i18n';
import { LEGACY } from '../i18n/legacy';
import { pageHref } from '../pages';
import { UNIVERSES, universeName } from '../universes';
import DeepDive from '../DeepDive.astro';

interface Props {
  base: string;
  lang?: Lang;
}

const { base, lang = 'pl' } = Astro.props;
const t = LEGACY[lang];
---

<header>
  <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-radar" aria-hidden="true"></span>{t.eyebrow}</p>
  <h1 set:html={t.h1Html} />
  <p class="sub" set:html={t.subHtml} />

  <div class="chainwrap">
    <svg class="chain" viewBox="0 0 960 260" role="img" aria-label={t.svgAria}>
      <path d="M20,132 H940" stroke="#7c8cff" opacity=".08" fill="none"/>
      <a href="#a-02" style="color:#7aa2ff" aria-label={t.svgNodeAria.radar}>
        <text class="ann" x="210" y="16" text-anchor="middle">{t.svg.annScan}</text>
        <circle cx="210" cy="132" r="105" fill="none" stroke="currentColor" opacity=".55" stroke-width="1.4"/>
        <circle cx="210" cy="132" r="70" fill="none" stroke="currentColor" opacity=".25"/>
        <circle cx="210" cy="132" r="35" fill="none" stroke="currentColor" opacity=".25"/>
        <path d="M105,132 H315 M210,27 V237" stroke="currentColor" opacity=".16" fill="none"/>
        <g class="anim-rot" style="animation-duration:10s">
          <circle cx="210" cy="132" r="105" fill="none" stroke="none"/>
          <path d="M210,132 L210,30" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M210,132 L210,30 A102,102 0 0 1 253,39 Z" fill="currentColor" opacity=".1" stroke="none"/>
        </g>
        <g stroke="currentColor" fill="none">
          <rect x="150" y="72" width="30" height="22" stroke-width="1.6"><animate attributeName="opacity" values="0;1;1;.25" keyTimes="0;.06;.9;1" dur="10s" repeatCount="indefinite"/></rect>
          <rect x="238" y="158" width="34" height="26" stroke-width="1.6"><animate attributeName="opacity" values="0;1;1;.25" keyTimes="0;.06;.9;1" dur="10s" begin="2.5s" repeatCount="indefinite"/></rect>
          <rect x="132" y="150" width="22" height="16" stroke-width=".8" opacity=".4"><animate attributeName="opacity" values="0;.4;.4;.1" keyTimes="0;.06;.9;1" dur="10s" begin="5s" repeatCount="indefinite"/></rect>
          <rect x="196" y="182" width="24" height="16" stroke-width=".8" opacity=".4"><animate attributeName="opacity" values="0;.4;.4;.1" keyTimes="0;.06;.9;1" dur="10s" begin="7.5s" repeatCount="indefinite"/></rect>
        </g>
        <text class="knum" x="210" y="254" text-anchor="middle">{t.svg.radarLabel}</text>
      </a>
      <a href="#a-03" style="color:#3ddad0" aria-label={t.svgNodeAria.hotspot}>
        <path d="M210,132 L210,27 A105,105 0 0 1 315,132 Z" fill="currentColor" opacity=".07" stroke="none"/>
        <circle cx="258" cy="94" r="6" fill="currentColor" class="anim-pulse"/>
        <circle cx="258" cy="94" r="14" fill="none" stroke="currentColor" class="anim-pulse"/>
        <text class="ann" x="342" y="52" text-anchor="middle">{t.svg.hotspotL1}<tspan x="342" y="65">{t.svg.hotspotL2}</tspan></text>
      </a>
      <g style="color:#7c8cff">
        <path d="M280,88 C 400,52 470,56 560,76" stroke="currentColor" stroke-dasharray="4 5" opacity=".5" fill="none" class="anim-dash"/>
        <circle r="7" fill="currentColor" opacity=".25"><animateMotion dur="6s" repeatCount="indefinite" path="M280,88 C 400,52 470,56 560,76"/></circle>
        <circle r="3" fill="#dce2f5" class="anim-pulse"><animateMotion dur="6s" repeatCount="indefinite" path="M280,88 C 400,52 470,56 560,76"/></circle>
        <rect class="kbox" x="560" y="24" width="370" height="214" stroke-width="1.4"/>
        <text class="knum" x="745" y="46" text-anchor="middle">{t.svg.reportTitle}</text>
        <path d="M576,54 H914" stroke="currentColor" opacity=".2" fill="none"/>
      </g>
      <a href="#a-01" style="color:#f0a64a" aria-label={t.svgNodeAria.item0}>
        <rect x="580" y="66" width="13" height="13" fill="none" stroke="currentColor"/>
        <path d="M582,72 l4,4 7,-8" stroke="currentColor" stroke-width="1.6" fill="none" opacity="0"><animate attributeName="opacity" values="0;0;1;1" keyTimes="0;.1;.13;1" dur="12s" repeatCount="indefinite"/></path>
        <text class="knum" x="604" y="77">{t.svg.items[0]}</text>
      </a>
      <a href="#a-02" style="color:#7aa2ff" aria-label={t.svgNodeAria.item1}>
        <rect x="580" y="94" width="13" height="13" fill="none" stroke="currentColor"/>
        <path d="M582,100 l4,4 7,-8" stroke="currentColor" stroke-width="1.6" fill="none" opacity="0"><animate attributeName="opacity" values="0;0;1;1" keyTimes="0;.22;.25;1" dur="12s" repeatCount="indefinite"/></path>
        <text class="knum" x="604" y="105">{t.svg.items[1]}</text>
      </a>
      <a href="#a-03" style="color:#3ddad0" aria-label={t.svgNodeAria.item23}>
        <rect x="580" y="122" width="13" height="13" fill="none" stroke="currentColor"/>
        <path d="M582,128 l4,4 7,-8" stroke="currentColor" stroke-width="1.6" fill="none" opacity="0"><animate attributeName="opacity" values="0;0;1;1" keyTimes="0;.34;.37;1" dur="12s" repeatCount="indefinite"/></path>
        <text class="knum" x="604" y="133">{t.svg.items[2]}</text>
        <rect x="580" y="150" width="13" height="13" fill="none" stroke="currentColor"/>
        <path d="M582,156 l4,4 7,-8" stroke="currentColor" stroke-width="1.6" fill="none" opacity="0"><animate attributeName="opacity" values="0;0;1;1" keyTimes="0;.46;.49;1" dur="12s" repeatCount="indefinite"/></path>
        <text class="knum" x="604" y="161">{t.svg.items[3]}</text>
      </a>
      <a href="#a-04" style="color:#e2564a" aria-label={t.svgNodeAria.item4}>
        <rect x="580" y="178" width="13" height="13" fill="none" stroke="currentColor"/>
        <path d="M582,184 l4,4 7,-8" stroke="currentColor" stroke-width="1.6" fill="none" opacity="0"><animate attributeName="opacity" values="0;0;1;1" keyTimes="0;.58;.61;1" dur="12s" repeatCount="indefinite"/></path>
        <text class="knum" x="604" y="189">{t.svg.items[4]}</text>
      </a>
      <a href="#a-05" style="color:#f472b6" aria-label={t.svgNodeAria.item5}>
        <rect x="580" y="206" width="13" height="13" fill="none" stroke="currentColor"/>
        <path d="M582,212 l4,4 7,-8" stroke="currentColor" stroke-width="1.6" fill="none" opacity="0"><animate attributeName="opacity" values="0;0;1;1" keyTimes="0;.7;.73;1" dur="12s" repeatCount="indefinite"/></path>
        <text class="knum" x="604" y="217">{t.svg.items[5]}</text>
      </a>
      <text class="ann" x="745" y="254" text-anchor="middle">{t.svg.annDefensible}</text>
    </svg>
    <p class="map-cap">{t.mapCap}</p>
  </div>

  <nav class="route" aria-label={t.routeAria}>
    <a href="#a-01" style="--hov:#f0a64a">{t.route[0]}</a>
    <a href="#a-02" style="--hov:#7aa2ff">{t.route[1]}</a>
    <a href="#a-03" style="--hov:#3ddad0">{t.route[2]}</a>
    <a href="#a-04" style="--hov:#e2564a">{t.route[3]}</a>
    <a href="#a-05" style="--hov:#f472b6">{t.route[4]}</a>
    <a href="#dalej">{t.route[5]}</a>
  </nav>
</header>

<!-- ============ SKRÓT ============ -->
<section id="skrot">
  <div class="rv">
    <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-star" aria-hidden="true"></span>{t.skrotEyebrow}</p>
  </div>
  <div class="sum-grid rv">
    <a class="sum-card" href="#a-01" style="--acc:#f0a64a">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><rect x="5" y="8" width="12" height="24"/><path d="M5,18 h12" opacity=".5"/><path d="M17,20 h5 M28,20 h7"/><path d="M22,16 l6,4 -6,4 z"/></g><circle cx="32" cy="27" r="2.4" fill="currentColor"/></svg>
      <span class="num">{t.cards[0].num}</span>
      <h3>{t.cards[0].h3}</h3>
      <p>{t.cards[0].p}</p>
    </a>
    <a class="sum-card" href="#a-02" style="--acc:#7aa2ff">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><path d="M11,17 C 18,9 24,7 31,7 M11,20 H31 M11,23 C 18,31 24,33 31,33" stroke-dasharray="2 3" opacity=".7"/><rect x="27" y="11" width="8" height="7"/><rect x="27" y="22" width="8" height="7" opacity=".5"/></g><circle cx="8" cy="20" r="3" fill="currentColor"/></svg>
      <span class="num">{t.cards[1].num}</span>
      <h3>{t.cards[1].h3}</h3>
      <p>{t.cards[1].p}</p>
    </a>
    <a class="sum-card" href="#a-03" style="--acc:#3ddad0">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><path d="M5,10 H35 M5,20 H35 M5,30 H35" opacity=".3"/><circle cx="27" cy="20" r="7"/></g><g fill="currentColor"><circle cx="13" cy="10" r="2" opacity=".6"/><circle cx="21" cy="30" r="2" opacity=".5"/><circle cx="27" cy="20" r="3.2"/></g></svg>
      <span class="num">{t.cards[2].num}</span>
      <h3>{t.cards[2].h3}</h3>
      <p>{t.cards[2].p}</p>
    </a>
    <a class="sum-card" href="#a-04" style="--acc:#e2564a">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><path d="M5,13 L20,5 35,13"/><path d="M8,13 V33 M32,13 V33 M5,33 h30"/><rect x="13" y="18" width="7" height="7"/><rect x="21" y="18" width="7" height="7" stroke-dasharray="2 2" opacity=".6"/><path d="M14,29 h10 m-3,-3 3,3 -3,3" opacity=".8"/></g></svg>
      <span class="num">{t.cards[3].num}</span>
      <h3>{t.cards[3].h3}</h3>
      <p>{t.cards[3].p}</p>
    </a>
    <a class="sum-card" href="#a-05" style="--acc:#f472b6">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><path d="M15,20 h6" opacity=".6"/><rect x="24" y="6" width="11" height="11"/><rect x="24" y="23" width="11" height="11"/></g><g fill="currentColor"><circle cx="8" cy="11" r="2" opacity=".5"/><circle cx="12" cy="21" r="1.6" opacity=".4"/><circle cx="7" cy="29" r="2.2" opacity=".6"/><circle cx="29.5" cy="11.5" r="1.6"/><circle cx="29.5" cy="28.5" r="1.6"/></g></svg>
      <span class="num">{t.cards[4].num}</span>
      <h3>{t.cards[4].h3}</h3>
      <p>{t.cards[4].p}</p>
    </a>
  </div>
  <div class="epigraph finis rv" style="--acc:var(--indigo)">
    <p>{t.skrotFinis}</p>
    <cite>{t.skrotFinisCite}</cite>
  </div>
</section>

<!-- ============ LEKCJA 01 SKALOWANIE KONTEKSTU ============ -->
<section class="sector" id="a-01" style="--acc:#f0a64a">
  <div class="sec-top rv">
    <div>
    <div class="sec-head">
      <span class="sec-num">{t.l1.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.diuna.glyph} />{universeName(UNIVERSES.diuna, lang)}{t.l1.uniSub}</span>
    </div>
    <h2>{t.l1.h2}</h2>
    <div class="epigraph sf-only">
      <p>{t.l1.epigraphSf}</p>
      <cite>{t.l1.epigraphCiteSf}</cite>
    </div>
    </div>
    <figure class="asset">
      <div class="a-vis">
        <svg viewBox="0 0 440 300" role="img" aria-label={t.l1.figAria}>
          <g stroke="currentColor" fill="none">
            <rect x="24" y="18" width="392" height="264" opacity=".4"/>
            <rect x="48" y="56" width="104" height="188"/>
            <rect x="52" y="122" width="96" height="118" fill="currentColor" opacity=".08" stroke="none"/>
            <path d="M52,122 h96" opacity=".7"/>
            <path d="M60,142 h80 M60,162 h80 M60,182 h64 M60,202 h72 M60,222 h56" opacity=".2"/>
            <path d="M152,150 H194 M226,150 H268" stroke-width="1.5"/>
            <path d="M196,138 v24 l26,-12 z" stroke-width="1.5"/>
            <path d="M224,138 v24 l-26,-12 z" stroke-width="1.5" opacity=".5"/>
            <path d="M210,136 V120 M200,120 h20" opacity=".6"/>
            <rect x="268" y="104" width="124" height="92" stroke-width="1.5"/>
            <path d="M280,128 h100 M280,146 h100 M280,164 h64" opacity=".3"/>
          </g>
          <path d="M196,138 v24 l26,-12 z" fill="none" stroke="currentColor" stroke-width="1.5" class="anim-pulse"/>
          <g fill="currentColor">
            <circle r="3"><animateMotion dur="3s" repeatCount="indefinite" path="M156,150 H262"/></circle>
            <circle r="3"><animateMotion dur="3s" begin="1s" repeatCount="indefinite" path="M156,150 H262"/></circle>
            <circle r="3"><animateMotion dur="3s" begin="2s" repeatCount="indefinite" path="M156,150 H262"/></circle>
          </g>
          <text x="100" y="44" text-anchor="middle">{t.l1.fig[0]}</text>
          <text x="100" y="264" text-anchor="middle" class="dim">{t.l1.fig[1]}</text>
          <text x="210" y="108" text-anchor="middle" class="acc">{t.l1.fig[2]}</text>
          <text x="330" y="88" text-anchor="middle" class="acc">{t.l1.fig[3]}</text>
          <text x="404" y="264" text-anchor="end" class="dim">{t.l1.fig[4]}</text>
        </svg>
      </div>
      <figcaption>{t.l1.figcaption}</figcaption>
    </figure>
  </div>

  <div class="cols rv">
    <div>
      <p class="lead sf-only" set:html={t.l1.leadSfHtml} />
      <p class="lead neutral-only" set:html={t.l1.leadNeutralHtml} />
      <p class="lead" set:html={t.l1.leadHtml} />
      <p class="mono" style="margin-top:16px">{t.l1.grunt}</p>
    </div>
    <dl class="mech">
      <div><dt><span class="ico ico-aim" aria-hidden="true"></span>{t.mechDt.question}</dt><dd class="v" style="margin:0">{t.l1.question}</dd></div>
      <div><dt><span class="ico ico-check" aria-hidden="true"></span>{t.mechDt.guarantee}</dt><dd class="v" style="margin:0">{t.l1.guarantee}</dd></div>
      <div><dt><span class="ico ico-doc" aria-hidden="true"></span>{t.mechDt.artifact}</dt><dd class="v" style="margin:0" set:html={t.l1.artifactHtml} /></div>
      <div><dt><span class="ico ico-wrench" aria-hidden="true"></span>{t.mechDt.tools}</dt><dd class="v" style="margin:0" set:html={t.l1.toolsHtml} /></div>
      <div><dt><span class="ico ico-link" aria-hidden="true"></span>{t.mechDt.lesson}</dt><dd class="v" style="margin:0"><a href={lessonUrl('16', lang)} style="color:var(--acc)">{t.l1.lessonLabel}</a></dd></div>
    </dl>
  </div>
  <div class="target rv">
    <span class="k"><span class="ico ico-aim" aria-hidden="true"></span>{t.targetK}</span>
    <p set:html={t.l1.targetHtml} />
  </div>
  <DeepDive skill="10x-agents-md" items={t.l1.dd} lang={lang} />
</section>

<!-- ============ LEKCJA 02 MAPA PROJEKTU ============ -->
<section class="sector" id="a-02" style="--acc:#7aa2ff">
  <div class="sec-top rv">
    <div>
    <div class="sec-head">
      <span class="sec-num">{t.l2.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.lem.glyph} />{universeName(UNIVERSES.lem, lang)}{t.l2.uniSub}</span>
    </div>
    <h2>{t.l2.h2}</h2>
    <div class="epigraph sf-only">
      <p>{t.l2.epigraphSf}</p>
      <cite>{t.l2.epigraphCiteSf}</cite>
    </div>
    </div>
    <figure class="asset">
      <div class="a-vis">
        <svg viewBox="0 0 440 300" role="img" aria-label={t.l2.figAria}>
          <g stroke="currentColor" fill="none">
            <rect x="24" y="18" width="392" height="264" opacity=".4"/>
            <path d="M52,150 l26,-14 v28 z" stroke-width="1.5"/>
            <rect x="78" y="136" width="26" height="28" stroke-width="1.5"/>
            <rect x="270" y="48" width="132" height="204"/>
            <path d="M314,48 V252 M358,48 V252 M270,116 H402 M270,184 H402" opacity=".18"/>
            <rect x="282" y="62" width="22" height="16" stroke-width="1.6"/>
            <rect x="322" y="128" width="26" height="18" stroke-width="1.6"/>
            <rect x="368" y="196" width="24" height="16" stroke-width="1.6"/>
            <rect x="326" y="66" width="18" height="12" stroke-width=".8" opacity=".35"/>
            <rect x="284" y="132" width="16" height="12" stroke-width=".8" opacity=".35"/>
            <rect x="288" y="200" width="18" height="12" stroke-width=".8" opacity=".35"/>
            <rect x="370" y="72" width="18" height="12" stroke-width=".8" opacity=".35"/>
            <path d="M104,150 C 160,84 210,66 268,66" stroke-dasharray="4 5" opacity=".45" class="anim-dash"/>
            <path d="M104,150 H268" stroke-dasharray="4 5" opacity=".45" class="anim-dash"/>
            <path d="M104,150 C 160,216 210,234 268,234" stroke-dasharray="4 5" opacity=".45" class="anim-dash"/>
          </g>
          <g fill="currentColor">
            <circle r="2.8"><animateMotion dur="5s" repeatCount="indefinite" path="M104,150 C 160,84 210,66 268,66 C 210,86 160,124 104,150"/></circle>
            <circle r="2.8"><animateMotion dur="5s" begin="1.7s" repeatCount="indefinite" path="M104,150 C 180,150 220,150 268,150 C 220,164 180,164 104,150"/></circle>
            <circle r="2.8"><animateMotion dur="5s" begin="3.4s" repeatCount="indefinite" path="M104,150 C 160,216 210,234 268,234 C 210,214 160,176 104,150"/></circle>
          </g>
          <text x="78" y="188" text-anchor="middle">{t.l2.fig[0]}</text>
          <text x="36" y="42">{t.l2.fig[1]}</text>
          <text x="336" y="38" text-anchor="middle" class="acc">{t.l2.fig[2]}</text>
          <text x="336" y="270" text-anchor="middle" class="dim">{t.l2.fig[3]}</text>
        </svg>
      </div>
      <figcaption>{t.l2.figcaption}</figcaption>
    </figure>
  </div>

  <div class="cols rv">
    <div>
      <p class="lead sf-only" set:html={t.l2.leadSfHtml} />
      <p class="lead neutral-only" set:html={t.l2.leadNeutralHtml} />
      <p class="lead" set:html={t.l2.leadHtml} />
      <p class="mono" style="margin-top:16px">{t.l2.grunt}</p>
    </div>
    <dl class="mech">
      <div><dt><span class="ico ico-aim" aria-hidden="true"></span>{t.mechDt.question}</dt><dd class="v" style="margin:0">{t.l2.question}</dd></div>
      <div><dt><span class="ico ico-check" aria-hidden="true"></span>{t.mechDt.guarantee}</dt><dd class="v" style="margin:0">{t.l2.guarantee}</dd></div>
      <div><dt><span class="ico ico-doc" aria-hidden="true"></span>{t.mechDt.artifact}</dt><dd class="v" style="margin:0" set:html={t.l2.artifactHtml} /></div>
      <div><dt><span class="ico ico-wrench" aria-hidden="true"></span>{t.mechDt.tools}</dt><dd class="v" style="margin:0" set:html={t.l2.toolsHtml} /></div>
      <div><dt><span class="ico ico-link" aria-hidden="true"></span>{t.mechDt.lesson}</dt><dd class="v" style="margin:0"><a href={lessonUrl('17', lang)} style="color:var(--acc)">{t.l2.lessonLabel}</a></dd></div>
    </dl>
  </div>
  <div class="target rv">
    <span class="k"><span class="ico ico-aim" aria-hidden="true"></span>{t.targetK}</span>
    <p set:html={t.l2.targetHtml} />
  </div>
  <DeepDive skill="10x-research" items={t.l2.dd} lang={lang} />
</section>

<!-- ============ LEKCJA 03 FEATURE + HOT SPOTS ============ -->
<section class="sector" id="a-03" style="--acc:#3ddad0">
  <div class="sec-top rv">
    <div>
    <div class="sec-head">
      <span class="sec-num">{t.l3.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.expanse.glyph} />{universeName(UNIVERSES.expanse, lang)}{t.l3.uniSub}</span>
    </div>
    <h2>{t.l3.h2}</h2>
    <div class="epigraph sf-only">
      <p>{t.l3.epigraphSf}</p>
      <cite>{t.l3.epigraphCiteSf}</cite>
    </div>
    </div>
    <figure class="asset">
      <div class="a-vis">
        <svg viewBox="0 0 440 300" role="img" aria-label={t.l3.figAria}>
          <g stroke="currentColor" fill="none">
            <rect x="24" y="18" width="392" height="264" opacity=".4"/>
            <path d="M48,80 H392 M48,160 H392 M48,240 H392" opacity=".25"/>
            <path d="M120,50 V262 M220,50 V262 M320,50 V262" opacity=".25"/>
            <circle cx="220" cy="160" r="10" opacity=".5"/>
            <circle cx="220" cy="160" r="17" opacity=".3"/>
          </g>
          <g fill="currentColor">
            <circle cx="120" cy="80" r="3" opacity=".4"/>
