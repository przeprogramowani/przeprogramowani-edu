    <div class="doc-tags"><span class="tag">m4</span><span class="tag">legacy</span><span class="tag">10xarchitect</span><span class="tag">raport architektoniczny</span><span class="tag">landing</span></div>
    <details class="doc-detal"><summary>Detal</summary>
      <dl class="mech">
