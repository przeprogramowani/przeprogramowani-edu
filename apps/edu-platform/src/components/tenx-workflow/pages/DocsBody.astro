details.doc-detal summary{
  cursor:pointer;list-style:none;display:inline-block;
  font-family:var(--disp);font-weight:600;font-size:.68rem;letter-spacing:.16em;
  text-transform:uppercase;color:color-mix(in srgb,var(--acc) 75%,var(--muted));
}
details.doc-detal summary::-webkit-details-marker{display:none}
details.doc-detal summary::before{content:'[+] '}
details.doc-detal[open] summary::before{content:'[-] '}
details.doc-detal summary:hover{color:var(--acc)}
.doc .mech{margin:8px 0 2px;border-top:1px solid var(--line);display:grid}
.doc .mech>div{display:grid;grid-template-columns:172px 1fr;gap:16px;
  padding:11px 0;border-bottom:1px solid var(--line-soft);align-items:baseline}
.doc .mech dt{font-family:var(--disp);font-weight:600;font-size:.72rem;
  letter-spacing:.14em;text-transform:uppercase;color:var(--acc);
  display:flex;align-items:center;gap:7px}
.doc .mech dt .ico{width:12px;height:12px}
.doc .mech .v{font-size:.89rem;color:var(--muted);margin:0}
.doc .mech .v b{color:var(--txt);font-weight:600}
@media(max-width:560px){.doc .mech>div{grid-template-columns:1fr;gap:4px}}

/* pusty wynik */
#empty{display:none;padding:44px 0;text-align:center;color:var(--dim)}
#empty.on{display:block}
#empty .chip{margin-left:12px}

/* ---------- druk / eksport do PDF ---------- */
@media print{
  html body{font-size:12px}
  .searchbar{display:none !important}
  article.doc,.doc .mech>div{break-inside:avoid}
  .mod-group{padding-top:8mm}
}
</style>

<script is:inline set:html={searchScript}></script>
