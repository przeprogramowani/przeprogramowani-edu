<style is:global>
/* ---------- docs: kompaktowe nadpisania wspolnego layoutu ---------- */
[hidden]{display:none !important}
html body{font-size:16px;line-height:1.6}
body .wrap{max-width:980px}
body header{padding:clamp(32px,6vh,60px) 0 26px;border-bottom:0}
header h1{
  font-size:clamp(1.55rem,3.8vw,2.3rem);font-weight:700;line-height:1.16;
