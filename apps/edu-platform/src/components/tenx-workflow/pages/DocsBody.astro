---
/**
 * Tresc strony "Dokumentacja (quick search)" - przeszukiwalny indeks calej
 * kampanii 10x Workflow (55 wpisow: strony, kroki, wezly, lekcje, skille).
 * Zrodlo: kampania 10xdevs-docs.html; hud (logo, breadcrumb, xnav), tlo,
 * gwiazdy i footer daje TenxCosmicLayout.
 */
import { lessonUrl } from '../config';
import { pageHref } from '../pages';
import { DOCS, type DocEntry } from '../docs-data';

interface Props {
  base: string;
}

const { base } = Astro.props;

/** Adres wpisu: strona docelowa z rejestru stron + opcjonalna kotwica. */
const doc = (slug: string, anchor?: string) =>
  anchor ? `${pageHref(base, slug)}#${anchor}` : pageHref(base, slug);

/* Dane wpisow zyja w ../docs-data.ts (wspolne ze strona i paleta wyszukiwania
   w TenxCosmicLayout). Ponizsza serializacja odtwarza literal DOCS w skrypcie
   inline 1:1 z historycznym formatem recznym (klucze bez cudzyslowow,
   apostrofy, wpis per linia, przecinek na koncu), zeby wyrenderowany HTML
   strony pozostal identyczny po ekstrakcji danych. */
const q = (s: string) => `'${s.replace(/\\/g, '\\\\').replace(/'/g, "\\'")}'`;
const docLine = (d: DocEntry) =>
  '{' +
  [
    `id:${q(d.id)}`,
    `typ:${q(d.typ)}`,
    `kind:${q(d.kind)}`,
    `modul:${q(d.modul)}`,
    `tytul:${q(d.tytul)}`,
    `streszczenie:${q(d.streszczenie)}`,
    `tagi:[${d.tagi.map(q).join(',')}]`,
    `artefakt:${d.artefakt === null ? 'null' : q(d.artefakt)}`,
    ...(d.url ? [`url:${q(d.url)}`] : []),
  ].join(',') +
  '},';

/* Pelna tresc skryptu wyszukiwarki (naglowek + const DOCS + IIFE) budowana we
   frontmatterze, bo Astro nie interpoluje wyrazen w <script is:inline>. */
const searchScript =
  `
/* Indeks wyszukiwarki. Karty wpisow sa wyrenderowane statycznie w HTML
   (czytelne bez JS); DOCS trzyma metadane do filtrowania - id musi
   odpowiadac data-id karty. Adresy stron zyja tylko w statycznych kartach
   (pageHref w szablonie), wiec DOCS ich nie trzyma; wpisy lekcji nosza
   dodatkowo \`url\` lekcji na platformie (/external/10xdevs-3/pl/NN). */
const DOCS = [
/* DOCS: dopisuj nowe wpisy poniżej */
` +
  DOCS.map(docLine).join('\n') +
  '\n];\n\n' +
  String.raw`(function(){
  var q=document.getElementById('q'),count=document.getElementById('count'),empty=document.getElementById('empty');
  var emptyMsg=document.getElementById('empty-msg'),emptyClear=document.getElementById('empty-clear');
  if(!q)return;
  var state={q:'',kind:'*',modul:'*'};
  function norm(s){return (s||'').toLowerCase().replace(/ł/g,'l').normalize('NFD').replace(/[\u0300-\u036f]/g,'');}
  DOCS.forEach(function(d){
    d._h=norm([d.tytul,d.streszczenie,(d.tagi||[]).join(' '),d.artefakt||''].join(' '));
    d._el=document.querySelector('article.doc[data-id="'+d.id+'"]');
  });
  function pl(n){var r=n%10,h=n%100;if(n===1)return'wpis';if(r>=2&&r<=4&&(h<12||h>14))return'wpisy';return'wpisów';}
  function apply(){
    var nq=norm(state.q),vis=0;
    DOCS.forEach(function(d){
      if(!d._el)return;
      var ok=(state.kind==='*'||d.kind===state.kind)&&(state.modul==='*'||d.modul===state.modul)&&(!nq||d._h.indexOf(nq)>-1);
      d._el.hidden=!ok;if(ok)vis++;
    });
    document.querySelectorAll('.mod-group').forEach(function(g){
      g.hidden=!g.querySelector('article.doc:not([hidden])');
    });
    count.textContent=vis+' '+pl(vis);
    if(vis===0&&emptyMsg){
      emptyMsg.textContent=state.q?'BRAK WYNIKÓW DLA „'+state.q.trim()+'” // ZMIEŃ FRAZĘ ALBO FILTRY':'BRAK WYNIKÓW // ZMIEŃ FRAZĘ ALBO FILTRY';
    }
    empty.classList.toggle('on',vis===0);
  }
  function chipGroup(attr,key){
    var chips=document.querySelectorAll('.chip[data-'+attr+']');
    chips.forEach(function(ch){
      ch.addEventListener('click',function(){
        chips.forEach(function(o){o.setAttribute('aria-pressed',o===ch?'true':'false');});
        state[key]=ch.getAttribute('data-'+attr);
        apply();
      });
    });
  }
  chipGroup('kind','kind');
  chipGroup('modul','modul');
  function resetAll(){
    q.value='';state.q='';state.kind='*';state.modul='*';
    document.querySelectorAll('.chip[data-kind],.chip[data-modul]').forEach(function(ch){
      var v=ch.getAttribute('data-kind')||ch.getAttribute('data-modul');
      ch.setAttribute('aria-pressed',v==='*'?'true':'false');
    });
    apply();
    q.focus();
  }
  if(emptyClear)emptyClear.addEventListener('click',resetAll);
  q.addEventListener('input',function(){state.q=q.value;apply();});
  document.addEventListener('keydown',function(e){
    if(e.key==='/'&&document.activeElement!==q){e.preventDefault();q.focus();}
    else if(e.key==='Escape'&&(state.q||document.activeElement===q)){q.value='';state.q='';apply();}
  });
  apply();
  if(window.matchMedia('(min-width:900px) and (hover:hover) and (pointer:fine)').matches){
    q.focus({preventScroll:true});
  }
})();` +
  '\n';
---

<header>
  <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-lens" aria-hidden="true"></span>DOKUMENTACJA // QUICK SEARCH</p>
  <h1>Cała mapa 10x Workflow <span class="glow">w jednym indeksie</span></h1>
  <p class="sub">Cała kampania w jednym przeszukiwalnym indeksie: <strong>M1 Fundament, CSC (M2), skalowanie, M3 Jakość, M4 Legacy, M5 Teamwork</strong> - strony, kroki, węzły, lekcje i skille. Wpisz frazę albo naciśnij <kbd>/</kbd> - lista filtruje się natychmiast. <strong>Escape</strong> czyści wyszukiwanie.</p>
</header>

<div class="searchbar" id="searchbar">
  <div class="search-row">
    <div class="search-box">
      <span class="ico ico-lens" aria-hidden="true"></span>
      <input id="q" type="search" autocomplete="off" placeholder="Szukaj: koncept, technika, flow, skill, artefakt… ( / przenosi tu kursor)" aria-label="Szukaj w dokumentacji">
    </div>
    <span id="count" class="mono" aria-live="polite">55 wpisów</span>
  </div>
  <div class="chips" role="group" aria-label="Filtr rodzaju wpisu">
    <span class="lbl mono">RODZAJ</span>
    <button type="button" class="chip" data-kind="*" aria-pressed="true">Wszystko</button>
    <button type="button" class="chip" data-kind="strona" aria-pressed="false">Strony</button>
    <button type="button" class="chip" data-kind="koncept" aria-pressed="false">Koncepty</button>
    <button type="button" class="chip" data-kind="technika" aria-pressed="false">Techniki</button>
    <button type="button" class="chip" data-kind="flow" aria-pressed="false">Flow</button>
  </div>
  <div class="chips" role="group" aria-label="Filtr modułu">
    <span class="lbl mono">MODUŁ</span>
    <button type="button" class="chip" data-modul="*" aria-pressed="true">Wszystkie</button>
    <button type="button" class="chip" data-modul="CSC" aria-pressed="false">CSC</button>
    <button type="button" class="chip" data-modul="M1" aria-pressed="false">M1</button>
    <button type="button" class="chip" data-modul="SKALOWANIE" aria-pressed="false">Skalowanie</button>
    <button type="button" class="chip" data-modul="M3" aria-pressed="false">M3</button>
    <button type="button" class="chip" data-modul="M4" aria-pressed="false">M4</button>
    <button type="button" class="chip" data-modul="M5" aria-pressed="false">M5</button>
  </div>
</div>
<noscript>
  <style is:inline>.searchbar{display:none}</style>
  <p class="mono noscript-note">WYSZUKIWARKA WYMAGA JAVASCRIPT - PONIŻEJ PEŁNA LISTA WPISÓW.</p>
</noscript>

<main id="results">

<!-- ============ START: STRONY MODULOW ============ -->
<section class="mod-group" id="mod-strony">
  <div class="mod-head"><h2>START // STRONY MODUŁÓW</h2></div>

  <article class="doc" data-id="m1" data-kind="strona" style="--acc:#7c8cff">
    <div class="doc-head">
      <span class="badge">STRONA</span>
      <h3><a href={doc('fundament')}>Moduł 1: Fundament - strona modułu</a></h3>
    </div>
    <p class="doc-sum">Pięć lekcji, które zamieniają mglisty pomysł w projekt gotowy do lotu: <b>PRD, skille, bootstrap, onboarding agenta i pierwszy deploy</b>. Rampa kończy się tam, gdzie startuje CSC.</p>
    <div class="doc-tags"><span class="tag">m1</span><span class="tag">fundament</span><span class="tag">moduł 1</span><span class="tag">landing</span><span class="tag">rampa startowa</span></div>
    <details class="doc-detal"><summary>Detal</summary>
      <dl class="mech">
        <div><dt><span class="ico ico-aim" aria-hidden="true"></span>Po co istnieje</dt><dd class="v">Mapa modułu 1: skąd biorą się jednostki pracy, zanim pierwsza zmiana wejdzie w new.</dd></div>
        <div><dt><span class="ico ico-fast" aria-hidden="true"></span>Wejście → wyjście</dt><dd class="v">Wejście: pomysł (greenfield) lub istniejące repo (brownfield). Wyjście: prd.md, roadmap.md i środowisko - scaffold, AGENTS.md, działający deploy.</dd></div>
        <div><dt><span class="ico ico-wrench" aria-hidden="true"></span>Mechanizm</dt><dd class="v">Pięć lekcji = pięć pytań fundamentu; każda kończy się artefaktem na dysku.</dd></div>
      </dl>
    </details>
  </article>

  <article class="doc" data-id="csc" data-kind="strona" style="--acc:#7c8cff">
    <div class="doc-head">
      <span class="badge">STRONA</span>
      <h3><a href={doc('csc')}>Core Skills Chain (CSC) - strona modułu</a></h3>
    </div>
    <p class="doc-sum">Rdzeń 10x Workflow: pięć skoków jednej jednostki pracy - <b>new → research → plan → implement → review</b>. Każdy krok zostawia artefakt na dysku.</p>
    <div class="doc-tags"><span class="tag">csc</span><span class="tag">workflow</span><span class="tag">łańcuch</span><span class="tag">moduł 2</span><span class="tag">landing</span></div>
    <details class="doc-detal"><summary>Detal</summary>
      <dl class="mech">
        <div><dt><span class="ico ico-aim" aria-hidden="true"></span>Po co istnieje</dt><dd class="v">Jedna mapa całego łańcucha: pokazuje, po co istnieje każdy krok i co gwarantuje, zanim wejdziesz w szczegóły pojedynczego skilla.</dd></div>
        <div><dt><span class="ico ico-fast" aria-hidden="true"></span>Wejście → wyjście</dt><dd class="v">Wejście: jednostka pracy z fundamentu (prd.md, roadmap.md). Wyjście: przejście new → review z artefaktem na dysku po każdym kroku.</dd></div>
        <div><dt><span class="ico ico-wrench" aria-hidden="true"></span>Mechanizm</dt><dd class="v">Kroki komunikują się plikami w <b>context/changes/&lt;change-id&gt;/</b> - artefakt zatrzymuje maszynę, człowiek zatwierdza, łańcuch rusza dalej.</dd></div>
      </dl>
