---
/**
 * Tresc strony 10xTop5 - Golden Nuggets. Zrodlo: 10xdevs-4-golden-nuggets.md;
 * piec kluczowych wartosci 10xDevs z dowodami i glosami uczestnikow.
 * Strona publiczna - pisana dla czytelnika spoza kursu. Kolory sektorow wg
 * kanonu uniwersow (universes.ts): n-01 Fundacja, n-02 Solaris, n-03 WH40k,
 * n-04 Trzy ciala, n-05 Hyperion. Etykiety sektorow: SEKTOR 01..05
 * (kotwice id="n-01".. zostaja - linkuje do nich kanon i CTA).
 * Hero: piec samorodkow-glifow uniwersow na orbicie (patent glyphAt z KanonBody).
 * Kazdy sektor: sec-top z figure.asset (schemat mechanizmu 440x300, wzorzec
 * CscBody/JakoscBody), potem .cols (lead + transmisje), mech i target.
 * hud-top, xnav, footer i wspolny CSS renderuje TenxCosmicLayout.
 * i18n: teksty w i18n/top5.ts (pl+en), markup i SVG wspolne; nazwy uniwersow
 * przez universeName(); zmiana tresci = zmiana obu jezykow w slowniku.
 */
import type { Lang } from '../i18n';
import { TOP5 } from '../i18n/top5';
import { pageHref } from '../pages';
import { UNIVERSES, universeName, type UniverseId } from '../universes';

interface Props {
  base: string;
  lang?: Lang;
}

const { base, lang = 'pl' } = Astro.props;
const t = TOP5[lang];

/** Glif uniwersum osadzony w duzym SVG (zagniezdzony <svg> z pozycja i rozmiarem). */
const glyphAt = (id: UniverseId, x: number, y: number, s = 24) =>
  UNIVERSES[id].glyph.replace('<svg ', `<svg x="${x}" y="${y}" width="${s}" height="${s}" `);

/** Wezly hero (geometria; teksty i aria w t.nodes wg tego samego indeksu). */
const NODES: {
  id: UniverseId;
  href: string;
  x: number;
  y: number;
  link: string;
  labelY: number;
  numY: number;
  hitY: number;
  hitH: number;
}[] = [
  { id: 'fundacja', href: '#n-01', x: 157, y: 133, link: 'M184,143 L424,156', labelY: 87, numY: 104, hitY: 72, hitH: 86 },
  { id: 'lem', href: '#n-02', x: 480, y: 72, link: 'M480,100 V128', labelY: 26, numY: 43, hitY: 10, hitH: 88 },
  { id: 'wh40k', href: '#n-03', x: 803, y: 133, link: 'M776,143 L536,156', labelY: 87, numY: 104, hitY: 72, hitH: 86 },
  { id: 'trzycia', href: '#n-04', x: 280, y: 231, link: 'M303,222 L424,184', labelY: 291, numY: 272, hitY: 206, hitH: 92 },
  { id: 'hyperion', href: '#n-05', x: 680, y: 231, link: 'M657,222 L536,184', labelY: 291, numY: 272, hitY: 206, hitH: 92 },
];

---

<style is:global>
/* Reguly specyficzne dla strony (diff vs CSS wspolny w TenxCosmicLayout) */
@media print{
  #n-01{break-before:auto}
}
</style>

<header>
  <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-star" aria-hidden="true"></span>{t.eyebrow}</p>
  <h1 set:html={t.h1Html} />
  <p class="sub"><Fragment set:html={t.subPreHtml} /><a href={pageHref(base, 'csc', lang)} style="color:var(--indigo)">{t.subLink}</a><Fragment set:html={t.subPostHtml} /></p>

  <div class="chainwrap">
    <svg class="chain" viewBox="0 0 960 300" role="img" aria-label={t.heroAria}>
      <ellipse cx="480" cy="160" rx="340" ry="88" fill="none" stroke="#7c8cff" opacity=".18" stroke-dasharray="4 6"/>
      <ellipse cx="480" cy="160" rx="250" ry="62" fill="none" stroke="#7c8cff" opacity=".08"/>
      <g fill="#8a93b8" opacity=".35">
        <circle cx="60" cy="42" r="1.4"/><circle cx="252" cy="26" r="1"/><circle cx="700" cy="30" r="1.3"/>
        <circle cx="902" cy="62" r="1"/><circle cx="76" cy="252" r="1.2"/><circle cx="892" cy="242" r="1.4"/>
        <circle cx="420" cy="272" r="1"/><circle cx="562" cy="286" r="1.2"/><circle cx="358" cy="118" r="1"/>
        <circle cx="608" cy="204" r="1"/>
      </g>
      {NODES.map((n) => (
        <path d={n.link} stroke={UNIVERSES[n.id].color} fill="none" stroke-dasharray="4 5" opacity=".3" class="anim-dash"/>
      ))}
      <g style="color:var(--indigo)">
        <rect class="kbox" x="428" y="132" width="104" height="56" stroke-width="1.4"/>
        <text class="knum" x="480" y="154" text-anchor="middle">{t.centerNum}</text>
        <text class="klbl" x="480" y="176" text-anchor="middle">{t.centerLbl}</text>
      </g>
      {NODES.map((n, i) => (
        <a href={n.href} style={`color:${UNIVERSES[n.id].color}`} aria-label={`${t.nodes[i].aria} (${universeName(UNIVERSES[n.id], lang)})`}>
          <rect x={n.x - 58} y={n.hitY} width="116" height={n.hitH} fill="transparent"/>
          <rect x={n.x - 13} y={n.y - 13} width="26" height="26" transform={`rotate(45 ${n.x} ${n.y})`} fill="none" stroke="currentColor" opacity=".35"/>
          <circle cx={n.x} cy={n.y} r="21" fill="none" stroke="currentColor" stroke-dasharray="3 5" opacity=".5"/>
          <Fragment set:html={glyphAt(n.id, n.x - 12, n.y - 12)} />
          <text class="knum" x={n.x} y={n.numY} text-anchor="middle">{t.nodes[i].num}</text>
          <text class="klbl" x={n.x} y={n.labelY} text-anchor="middle">{t.nodes[i].label}</text>
        </a>
      ))}
      <circle r="7" fill="#7c8cff" opacity=".25"><animateMotion dur="12s" repeatCount="indefinite" path="M140,160 a340,88 0 1,0 680,0 a340,88 0 1,0 -680,0"/></circle>
      <circle r="3" fill="#dce2f5" class="anim-pulse"><animateMotion dur="12s" repeatCount="indefinite" path="M140,160 a340,88 0 1,0 680,0 a340,88 0 1,0 -680,0"/></circle>
      <circle r="2" fill="#7c8cff" opacity=".5"><animateMotion dur="18s" repeatCount="indefinite" path="M820,160 a340,88 0 1,1 -680,0 a340,88 0 1,1 680,0"/></circle>
    </svg>
    <p class="map-cap">{t.mapCapPre}<span class="sf-only">{t.mapCapSf}</span><span class="neutral-only">{t.mapCapNeutral}</span>{t.mapCapPost}</p>
  </div>

  <nav class="route" aria-label={t.routeAria}>
    <a href="#n-01" style="--hov:#f472b6">{t.route[0]}</a>
    <a href="#n-02" style="--hov:#7aa2ff">{t.route[1]}</a>
    <a href="#n-03" style="--hov:#e2564a">{t.route[2]}</a>
    <a href="#n-04" style="--hov:#4cc9f0">{t.route[3]}</a>
    <a href="#n-05" style="--hov:#a78bfa">{t.route[4]}</a>
    <a href="#dalej">{t.route[5]}</a>
  </nav>
</header>

<!-- ============ SKRÓT ============ -->
