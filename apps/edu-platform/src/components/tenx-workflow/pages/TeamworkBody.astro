---
/**
 * Tresc strony "Modul 5: Teamwork" (10x Workflow).
 * Transplant <body> z kampanii 10xdevs-teamwork.html; kolory sekcji
 * przefarbowane na kanon uniwersow (universes.ts), linki miedzy stronami
 * przez pageHref, glify uniwersow w sec-uni.
 * i18n: teksty w i18n/teamwork.ts (pl+en), markup i SVG wspolne;
 * zmiana tresci = zmiana obu jezykow w slowniku.
 */
import { lessonUrl } from '../config';
import type { Lang } from '../i18n';
import { TEAMWORK } from '../i18n/teamwork';
import { pageHref } from '../pages';
import { UNIVERSES, universeName } from '../universes';
import DeepDive from '../DeepDive.astro';

interface Props {
  base: string;
  lang?: Lang;
}

const { base, lang = 'pl' } = Astro.props;
const t = TEAMWORK[lang];
---

<header>
  <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-sig" aria-hidden="true"></span>{t.hdr.eyebrow}</p>
  <h1 set:html={t.hdr.h1Html} />
  <p class="sub" set:html={t.hdr.subHtml} />

  <div class="chainwrap">
    <svg class="chain" viewBox="0 0 960 260" role="img" aria-label={t.hdr.svgAria}>
      <text x="40" y="24" class="dim">{t.hdr.svgTitle}</text>
      <text x="40" y="248" class="ann">{t.hdr.svgPacks}</text>
      <!-- orbita dekoracyjna -->
      <g class="anim-rot" style="animation-duration:40s">
        <circle cx="480" cy="130" r="99" fill="none" stroke="none"/>
        <circle cx="480" cy="130" r="95" fill="none" stroke="#7c8cff" opacity=".22" stroke-dasharray="2 7"/>
        <circle cx="575" cy="130" r="3" fill="#7c8cff" opacity=".7"/>
      </g>
      <!-- węzeł centralny -->
      <g style="color:#7c8cff">
        <circle class="kbox" cx="480" cy="130" r="30" stroke-width="1.6"/>
        <circle cx="480" cy="130" r="4" fill="currentColor"/>
        <circle cx="480" cy="130" r="12" fill="none" stroke="currentColor" opacity=".5"/>
        <text class="klbl" x="480" y="186" text-anchor="middle">{t.hdr.svgTeam}</text>
      </g>
      <!-- 01 narzędzie -->
      <a href="#t-01" style="color:#3ddad0" aria-label={t.hdr.node.tool.aria}>
        <path d="M450,122 C 370,108 250,92 178,88" stroke="currentColor" stroke-dasharray="4 5" opacity=".5" fill="none" class="anim-dash"/>
        <text class="ann" x="160" y="42" text-anchor="middle">{t.hdr.node.tool.ann}</text>
        <circle class="kbox" cx="160" cy="85" r="16" stroke-width="1.5"/>
        <path d="M153,85 h14 M160,78 v14" stroke="currentColor" fill="none"/>
        <text class="knum" x="160" y="122" text-anchor="middle">{t.hdr.node.tool.k}</text>
      </a>
      <!-- 02 agent -->
      <a href="#t-02" style="color:#4ade9b" aria-label={t.hdr.node.agent.aria}>
        <path d="M462,156 C 430,190 385,212 348,220" stroke="currentColor" stroke-dasharray="4 5" opacity=".5" fill="none" class="anim-dash"/>
        <text class="ann" x="285" y="196" text-anchor="middle">{t.hdr.node.agent.ann}</text>
        <circle class="kbox" cx="330" cy="222" r="16" stroke-width="1.5"/>
        <g stroke="currentColor" fill="none"><rect x="322" y="214" width="7" height="7"/><rect x="331" y="214" width="7" height="7"/><rect x="326.5" y="223" width="7" height="7"/></g>
        <text class="knum" x="330" y="254" text-anchor="middle">{t.hdr.node.agent.k}</text>
      </a>
      <!-- 03 review-ci (pulsuje: każdy PR) -->
      <a href="#t-03" style="color:#7aa2ff" aria-label={t.hdr.node.review.aria}>
        <path d="M498,156 C 530,190 575,212 612,220" stroke="currentColor" stroke-dasharray="4 5" opacity=".5" fill="none" class="anim-dash"/>
        <text class="ann" x="700" y="196" text-anchor="middle">{t.hdr.node.review.ann}</text>
        <circle cx="630" cy="222" r="25" fill="none" stroke="currentColor" class="anim-pulse"/>
        <circle class="kbox" cx="630" cy="222" r="16" stroke-width="1.5"/>
        <circle cx="630" cy="222" r="4.5" fill="currentColor"/>
        <text class="knum" x="630" y="254" text-anchor="middle">{t.hdr.node.review.k}</text>
      </a>
      <!-- 04 rejestr -->
      <a href="#t-04" style="color:#f472b6" aria-label={t.hdr.node.registry.aria}>
        <path d="M510,122 C 590,108 710,92 782,88" stroke="currentColor" stroke-dasharray="4 5" opacity=".5" fill="none" class="anim-dash"/>
        <text class="ann" x="800" y="42" text-anchor="middle">{t.hdr.node.registry.ann}</text>
        <circle class="kbox" cx="800" cy="85" r="16" stroke-width="1.5"/>
        <path d="M793,78 v14 h14 v-14 z M800,78 v14" stroke="currentColor" fill="none"/>
        <text class="knum" x="800" y="122" text-anchor="middle">{t.hdr.node.registry.k}</text>
      </a>
      <!-- 05 async -->
      <a href="#t-05" style="color:#ff4f6e" aria-label={t.hdr.node.async.aria}>
        <path d="M480,100 L480,44" stroke="currentColor" stroke-dasharray="4 5" opacity=".5" fill="none" class="anim-dash"/>
        <circle class="kbox" cx="480" cy="28" r="14" stroke-width="1.5"/>
        <path d="M474,33 l6,-11 6,11 -6,-4 z" fill="currentColor"/>
        <text class="knum" x="503" y="32">{t.hdr.node.async.k}</text>
        <text class="ann" x="562" y="32">{t.hdr.node.async.ann}</text>
      </a>
      <!-- paczki skilli z rejestru -->
      <g fill="#f472b6">
        <rect x="-3.5" y="-3.5" width="7" height="7"><animateMotion dur="5s" repeatCount="indefinite" path="M796,100 C 710,112 590,122 514,128"/></rect>
        <rect x="-3" y="-3" width="6" height="6"><animateMotion dur="7s" begin="1.4s" repeatCount="indefinite" path="M798,68 C 700,4 300,4 168,68"/></rect>
        <rect x="-3" y="-3" width="6" height="6"><animateMotion dur="6s" begin="2.6s" repeatCount="indefinite" path="M802,102 C 780,170 700,206 648,217"/></rect>
        <rect x="-3" y="-3" width="6" height="6"><animateMotion dur="8s" begin="3.8s" repeatCount="indefinite" path="M788,98 C 690,190 470,240 348,226"/></rect>
        <rect x="-3" y="-3" width="6" height="6"><animateMotion dur="6.5s" begin="5s" repeatCount="indefinite" path="M786,76 C 700,34 580,20 496,26"/></rect>
      </g>
    </svg>
    <p class="map-cap">{t.hdr.mapCap}</p>
  </div>

  <nav class="route" aria-label={t.hdr.routeAria}>
    <a href="#t-01" style="--hov:#3ddad0">{t.hdr.route[0]}</a>
    <a href="#t-02" style="--hov:#4ade9b">{t.hdr.route[1]}</a>
    <a href="#t-03" style="--hov:#7aa2ff">{t.hdr.route[2]}</a>
    <a href="#t-04" style="--hov:#f472b6">{t.hdr.route[3]}</a>
    <a href="#t-05" style="--hov:#ff4f6e">{t.hdr.route[4]}</a>
    <a href="#dalej">{t.hdr.route[5]}</a>
  </nav>
</header>

<!-- ============ SKRÓT ============ -->
<section id="skrot">
  <div class="rv">
    <p class="eyebrow" style="--acc:var(--indigo)"><span class="ico ico-star" aria-hidden="true"></span>{t.sum.eyebrow}</p>
  </div>
  <div class="sum-grid rv">
    <a class="sum-card" href="#t-01" style="--acc:#3ddad0">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><rect x="4" y="13" width="12" height="10"/><rect x="24" y="13" width="12" height="10"/><path d="M17,30 h6 M20,30 V24" opacity=".8"/><path d="M17,24 l3,-4 3,4"/></g><circle cx="20" cy="33" r="2.5" fill="currentColor"/></svg>
      <span class="num">{t.sum.cards[0].num}</span>
      <h3>{t.sum.cards[0].h3}</h3>
      <p>{t.sum.cards[0].p}</p>
    </a>
    <a class="sum-card" href="#t-02" style="--acc:#4ade9b">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><rect x="5" y="5" width="9" height="9"/><rect x="5" y="18" width="9" height="9"/><rect x="5" y="31" width="9" height="4"/><rect x="22" y="12" width="14" height="14"/><path d="M14,9 h5 M14,22 h5" opacity=".6"/></g><circle cx="29" cy="19" r="2.5" fill="currentColor"/></svg>
      <span class="num">{t.sum.cards[1].num}</span>
      <h3>{t.sum.cards[1].h3}</h3>
      <p>{t.sum.cards[1].p}</p>
    </a>
    <a class="sum-card" href="#t-03" style="--acc:#7aa2ff">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><circle cx="20" cy="17" r="8"/><path d="M4,32 C 10,24 30,24 36,32" opacity=".6"/><path d="M33,29 l3,3 -4,1" opacity=".6"/></g><circle cx="20" cy="17" r="3" fill="currentColor"/></svg>
      <span class="num">{t.sum.cards[2].num}</span>
      <h3>{t.sum.cards[2].h3}</h3>
      <p>{t.sum.cards[2].p}</p>
    </a>
    <a class="sum-card" href="#t-04" style="--acc:#f472b6">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><rect x="5" y="8" width="14" height="24"/><path d="M12,8 v24" opacity=".5"/><path d="M23,14 h12 M23,20 h12 M23,26 h12" stroke-dasharray="2 3" opacity=".8"/></g><circle cx="36" cy="14" r="2" fill="currentColor"/><circle cx="36" cy="20" r="2" fill="currentColor"/><circle cx="36" cy="26" r="2" fill="currentColor"/></svg>
      <span class="num">{t.sum.cards[3].num}</span>
      <h3>{t.sum.cards[3].h3}</h3>
      <p>{t.sum.cards[3].p}</p>
    </a>
    <a class="sum-card" href="#t-05" style="--acc:#ff4f6e">
      <svg viewBox="0 0 40 40" aria-hidden="true"><g stroke="currentColor" fill="none" stroke-width="1.5"><path d="M6,14 l6,-8 6,8 -6,-4 z"/><path d="M22,26 l6,-8 6,8 -6,-4 z"/><path d="M8,22 C 12,30 20,33 30,32" stroke-dasharray="2 3" opacity=".7"/></g><circle cx="7" cy="31" r="2.5" fill="currentColor"/></svg>
      <span class="num">{t.sum.cards[4].num}</span>
      <h3>{t.sum.cards[4].h3}</h3>
      <p>{t.sum.cards[4].p}</p>
    </a>
  </div>
  <div class="epigraph finis rv" style="--acc:var(--indigo)">
    <p>{t.sum.finis}</p>
    <cite>{t.sum.finisCite}</cite>
  </div>
</section>

<!-- ============ LEKCJA 01 AI INTERNAL BUILDERS ============ -->
<section class="sector" id="t-01" style="--acc:#3ddad0">
  <div class="sec-top rv">
    <div>
    <div class="sec-head">
      <span class="sec-num">{t.l1.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.expanse.glyph} />{universeName(UNIVERSES.expanse, lang)} · {t.l1.uniSub}</span>
    </div>
    <h2>{t.l1.h2}</h2>
    <div class="epigraph sf-only">
      <p>{t.l1.epigraphSf}</p>
      <cite>{t.l1.epigraphCiteSf}</cite>
    </div>
    </div>
    <figure class="asset">
      <div class="a-vis">
        <svg viewBox="0 0 440 300" role="img" aria-label={t.l1.fig.aria}>
          <g stroke="currentColor" fill="none">
            <rect x="24" y="18" width="392" height="264" opacity=".4"/>
            <rect x="48" y="110" width="96" height="44"/>
            <rect x="296" y="110" width="96" height="44"/>
            <path d="M144,132 H182" stroke-dasharray="4 5" opacity=".65" class="anim-dash"/>
            <path d="M258,132 H296" stroke-dasharray="4 5" opacity=".65" class="anim-dash"/>
            <rect x="172" y="216" width="96" height="40" stroke-width="1.5"/>
            <path d="M220,216 V166" stroke-dasharray="4 5" opacity=".8" class="anim-dash"/>
            <path d="M215,172 l5,-8 5,8" stroke-width="1.5"/>
            <rect x="182" y="112" width="76" height="40" stroke-width="1.5" class="anim-pulse"/>
          </g>
          <path d="M213,125 l14,14 M227,125 l-14,14" stroke="#e2564a" opacity=".55" fill="none" class="anim-flicker"/>
          <circle r="2.6" fill="currentColor"><animateMotion dur="4s" repeatCount="indefinite" path="M144,132 H296"/></circle>
          <text x="96" y="135" text-anchor="middle">{t.l1.fig.data}</text>
          <text x="344" y="135" text-anchor="middle">{t.l1.fig.decision}</text>
          <text x="220" y="100" text-anchor="middle" class="acc">{t.l1.fig.gap}</text>
          <text x="220" y="272" text-anchor="middle" class="acc">{t.l1.fig.helper}</text>
          <text x="36" y="42" class="dim">{t.l1.fig.buy}</text>
          <text x="404" y="200" text-anchor="end" class="dim">{t.l1.fig.build}</text>
        </svg>
      </div>
      <figcaption>{t.l1.fig.caption}</figcaption>
    </figure>
  </div>

  <div class="cols rv">
    <div>
      <p class="lead sf-only" set:html={t.l1.leadSfHtml} />
      <p class="lead neutral-only" set:html={t.l1.leadNeutralHtml} />
      <p class="lead" set:html={t.l1.leadHtml} />
    </div>
    <dl class="mech">
      <div><dt><span class="ico ico-aim" aria-hidden="true"></span>{t.mech.q}</dt><dd class="v" style="margin:0">{t.l1.mechQ}</dd></div>
      <div><dt><span class="ico ico-check" aria-hidden="true"></span>{t.mech.g}</dt><dd class="v" style="margin:0">{t.l1.mechG}</dd></div>
      <div><dt><span class="ico ico-doc" aria-hidden="true"></span>{t.mech.a}</dt><dd class="v" style="margin:0" set:html={t.l1.mechAHtml} /></div>
      <div><dt><span class="ico ico-wrench" aria-hidden="true"></span>{t.mech.t}</dt><dd class="v" style="margin:0" set:html={t.l1.mechTHtml} /></div>
      <div><dt><span class="ico ico-link" aria-hidden="true"></span>{t.mech.l}</dt><dd class="v" style="margin:0"><a href={lessonUrl('21', lang)} style="color:var(--acc)">{t.l1.lessonLabel}</a></dd></div>
    </dl>
  </div>
  <div class="target rv">
    <span class="k"><span class="ico ico-aim" aria-hidden="true"></span>{t.targetK}</span>
    <p set:html={t.l1.targetHtml} />
  </div>
  <DeepDive skill="10x-prd" items={t.dd.builders} lang={lang} />
</section>

<!-- ============ LEKCJA 02 PIERWSZY AGENT ZESPOŁOWY ============ -->
<section class="sector" id="t-02" style="--acc:#4ade9b">
  <div class="sec-top rv">
    <div>
    <div class="sec-head">
      <span class="sec-num">{t.l2.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.ender.glyph} />{universeName(UNIVERSES.ender, lang)} · {t.l2.uniSub}</span>
    </div>
    <h2>{t.l2.h2}</h2>
    <div class="epigraph sf-only">
      <p>{t.l2.epigraphSf}</p>
      <cite>{t.l2.epigraphCiteSf}</cite>
    </div>
    </div>
    <figure class="asset">
      <div class="a-vis">
        <svg viewBox="0 0 440 300" role="img" aria-label={t.l2.fig.aria}>
          <g stroke="currentColor" fill="none">
            <rect x="24" y="18" width="392" height="264" opacity=".4"/>
            <rect x="48" y="58" width="96" height="30"/>
            <rect x="48" y="108" width="96" height="30"/>
            <rect x="48" y="158" width="96" height="30"/>
            <rect x="48" y="208" width="96" height="30"/>
            <path d="M144,73 C 190,80 200,110 210,128" stroke-dasharray="4 5" opacity=".6" class="anim-dash"/>
            <path d="M144,123 C 180,128 195,138 208,142" stroke-dasharray="4 5" opacity=".6" class="anim-dash"/>
            <path d="M144,173 C 180,168 195,160 208,154" stroke-dasharray="4 5" opacity=".6" class="anim-dash"/>
            <path d="M144,223 C 190,216 200,186 210,168" stroke-dasharray="4 5" opacity=".6" class="anim-dash"/>
            <rect x="210" y="108" width="90" height="84" stroke-width="1.5"/>
            <path d="M224,128 h62 M224,144 h62 M224,160 h44" opacity=".4"/>
            <path d="M300,150 H332" stroke-dasharray="4 5" opacity=".6" class="anim-dash"/>
            <circle cx="368" cy="160" r="34" stroke-width="1.5"/>
            <path d="M342,178 a34,34 0 0 1 52,0" opacity=".45"/>
          </g>
          <g stroke="currentColor" fill="none" stroke-width="2">
            <path d="M368,160 L388,136">
              <animateTransform attributeName="transform" type="rotate" values="-26 368 160;20 368 160;-26 368 160" dur="2.4s" repeatCount="indefinite"/>
            </path>
          </g>
          <circle cx="368" cy="160" r="3.5" fill="currentColor"/>
          <circle r="2.6" fill="currentColor"><animateMotion dur="3.6s" repeatCount="indefinite" path="M144,73 C 190,80 200,110 210,128"/></circle>
          <circle r="2.6" fill="currentColor"><animateMotion dur="3.6s" begin="1.2s" repeatCount="indefinite" path="M144,173 C 180,168 195,160 208,154"/></circle>
          <text x="96" y="77" text-anchor="middle">{t.l2.fig.model}</text>
          <text x="96" y="127" text-anchor="middle">{t.l2.fig.tools}</text>
          <text x="96" y="177" text-anchor="middle">{t.l2.fig.loop}</text>
          <text x="96" y="227" text-anchor="middle">{t.l2.fig.context}</text>
          <text x="255" y="98" text-anchor="middle" class="acc">{t.l2.fig.agent}</text>
          <text x="368" y="216" text-anchor="middle" class="acc">{t.l2.fig.meter}</text>
          <text x="36" y="42" class="dim">{t.l2.fig.fork}</text>
          <text x="404" y="268" text-anchor="end" class="dim">{t.l2.fig.metrics}</text>
        </svg>
      </div>
      <figcaption>{t.l2.fig.caption}</figcaption>
    </figure>
  </div>

  <div class="cols rv">
    <div>
      <p class="lead sf-only" set:html={t.l2.leadSfHtml} />
      <p class="lead neutral-only" set:html={t.l2.leadNeutralHtml} />
      <p class="lead" set:html={t.l2.leadHtml} />
    </div>
    <dl class="mech">
      <div><dt><span class="ico ico-aim" aria-hidden="true"></span>{t.mech.q}</dt><dd class="v" style="margin:0">{t.l2.mechQ}</dd></div>
      <div><dt><span class="ico ico-check" aria-hidden="true"></span>{t.mech.g}</dt><dd class="v" style="margin:0">{t.l2.mechG}</dd></div>
      <div><dt><span class="ico ico-doc" aria-hidden="true"></span>{t.mech.a}</dt><dd class="v" style="margin:0" set:html={t.l2.mechAHtml} /></div>
      <div><dt><span class="ico ico-wrench" aria-hidden="true"></span>{t.mech.t}</dt><dd class="v" style="margin:0" set:html={t.l2.mechTHtml} /></div>
      <div><dt><span class="ico ico-link" aria-hidden="true"></span>{t.mech.l}</dt><dd class="v" style="margin:0"><a href={lessonUrl('22', lang)} style="color:var(--acc)">{t.l2.lessonLabel}</a></dd></div>
    </dl>
  </div>
  <div class="target rv">
    <span class="k"><span class="ico ico-aim" aria-hidden="true"></span>{t.targetK}</span>
    <p set:html={t.l2.targetHtml} />
  </div>
</section>

<!-- ============ LEKCJA 03 CODE REVIEW W ERZE AI ============ -->
<section class="sector" id="t-03" style="--acc:#7aa2ff">
  <div class="sec-top rv">
    <div>
    <div class="sec-head">
      <span class="sec-num">{t.l3.num}</span>
      <span class="sec-uni sf-only"><Fragment set:html={UNIVERSES.lem.glyph} />{universeName(UNIVERSES.lem, lang)} · {t.l3.uniSub}</span>
    </div>
    <h2>{t.l3.h2}</h2>
    <div class="epigraph sf-only">
      <p>{t.l3.epigraphSf}</p>
      <cite>{t.l3.epigraphCiteSf}</cite>
    </div>
    </div>
    <figure class="asset">
      <div class="a-vis">
        <svg viewBox="0 0 440 300" role="img" aria-label={t.l3.fig.aria}>
          <g stroke="currentColor" fill="none">
            <rect x="24" y="18" width="392" height="264" opacity=".4"/>
            <rect x="48" y="120" width="80" height="40"/>
            <rect x="322" y="120" width="80" height="40"/>
            <path d="M128,140 H182" stroke-dasharray="4 5" opacity=".65" class="anim-dash"/>
            <path d="M258,140 H322" stroke-dasharray="4 5" opacity=".65" class="anim-dash"/>
            <path d="M252,134 l9,6 -10,4"/>
            <circle cx="220" cy="140" r="38" stroke-width="1.5"/>
            <path d="M362,160 C 362,244 88,244 88,160" stroke-dasharray="4 5" opacity=".5" class="anim-dash-slow"/>
            <path d="M83,168 l5,-9 6,8"/>
          </g>
          <circle cx="220" cy="140" r="6" fill="currentColor" class="anim-pulse"/>
          <circle cx="220" cy="140" r="18" fill="none" stroke="currentColor" opacity=".55" class="anim-pulse"/>
          <path d="M204,140 a16,10 0 0 1 32,0 a16,10 0 0 1 -32,0" stroke="currentColor" fill="none" opacity=".6"/>
          <circle r="2.8" fill="currentColor"><animateMotion dur="5s" repeatCount="indefinite" path="M128,140 H322"/></circle>
          <circle r="2.4" fill="currentColor" opacity=".7"><animateMotion dur="6s" begin="2s" repeatCount="indefinite" path="M362,160 C 362,244 88,244 88,160"/></circle>
          <text x="88" y="144" text-anchor="middle">{t.l3.fig.pr}</text>
          <text x="362" y="144" text-anchor="middle">{t.l3.fig.merge}</text>
          <text x="220" y="90" text-anchor="middle" class="acc">{t.l3.fig.observer}</text>
          <text x="220" y="232" text-anchor="middle" class="dim">{t.l3.fig.loop}</text>
          <text x="36" y="42" class="dim">{t.l3.fig.severity}</text>
          <text x="404" y="42" text-anchor="end" class="acc">{t.l3.fig.comment}</text>
          <text x="404" y="268" text-anchor="end" class="dim">{t.l3.fig.triage}</text>
        </svg>
      </div>
      <figcaption>{t.l3.fig.caption}</figcaption>
    </figure>
