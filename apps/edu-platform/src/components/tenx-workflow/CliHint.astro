---
/**
 * Kaflik 10x-cli doklejany na stronach skilli (i innych stronach lekcji).
 * Przypomina, ze zasoby lekcji pobiera sie w terminalu (10x get <id>) i linkuje
 * do strony narzedzia (kontekst publiczny) lub repo (kontekst gated, gdzie
 * strona 10x-cli nie istnieje). Komenda i repo czytane z config (TENX_CLI).
 *
 * Styl scoped (nie global) - Astro wstrzyknie CSS raz, niezaleznie od liczby
 * wystapien na stronie.
 */
import type { Lang } from './i18n';
import { PUBLIC_BASE, TENX_CLI } from './config';
import { pageHref } from './pages';

interface Props {
  base: string;
  lang?: Lang;
  /** Nazwa skilla do pobrania po nazwie (np. "10x-new"); brak = generyczny get. */
  skill?: string;
}

const { base, lang = 'pl', skill } = Astro.props;
// Strona 10x-cli istnieje tylko publicznie; w kontekscie gated linkujemy repo.
const isPublic = base === PUBLIC_BASE;
const href = isPublic ? pageHref(base, '10x-cli', lang) : TENX_CLI.repo;
const external = !isPublic;
// Skill po nazwie: 10x get <lekcja> --type skills --name <skill>; inaczej get <id>.
const cmd = skill ? TENX_CLI.skillCmd(skill) : '10x get <id>';
const intro = skill
  ? lang === 'en'
    ? 'Pull just this skill into your project from the terminal: '
    : 'Pobierz sam ten skill do projektu z terminala: '
  : lang === 'en'
    ? 'Pull this lesson’s resources into your project from the terminal: '
    : 'Zasoby tej lekcji wciągniesz do projektu z terminala: ';
---

<aside class="cli-hint">
  <span class="ch-k"><span class="ico ico-cli" aria-hidden="true"></span>10X-CLI</span>
  <p class="ch-t">
    {intro}
    <code set:html={cmd.replace(/</g, '&lt;').replace(/>/g, '&gt;')} />.
    {' '}
    <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>10x-cli →</a>
  </p>
</aside>

<style>
.cli-hint{display:flex;gap:14px;align-items:baseline;flex-wrap:wrap;margin:22px 0 0;
  padding:12px 16px;border:1px dashed color-mix(in srgb,#3ddad0 45%,transparent);
  background:color-mix(in srgb,var(--surface) 45%,transparent)}
.ch-k{font-family:var(--disp);font-weight:700;font-size:.68rem;letter-spacing:.18em;color:#3ddad0;
  display:inline-flex;align-items:center;gap:7px;flex:none}
.ch-k .ico{background:#3ddad0;width:12px;height:12px}
.ch-t{font-size:.88rem;color:var(--muted);line-height:1.5;margin:0}
.ch-t code{font-family:var(--mono);font-size:.85em;background:color-mix(in srgb,var(--surface) 80%,transparent);
  padding:1px 6px;color:#3ddad0}
.ch-t a{color:#3ddad0;text-decoration:none;border-bottom:1px solid color-mix(in srgb,#3ddad0 45%,transparent);white-space:nowrap}
.ch-t a:hover,.ch-t a:focus-visible{color:var(--txt);outline:none}
</style>
