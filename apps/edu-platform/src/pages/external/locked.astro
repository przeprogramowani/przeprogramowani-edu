---
import SharedLessonLayout from '@/layouts/SharedLessonLayout.astro';
---

<SharedLessonLayout title="Lekcja nie została znaleziona">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md mx-auto text-center">
      <div class="bg-gray-800 rounded-xl p-8 shadow-lg">
        <div class="text-6xl mb-6">🔒</div>

        <h1 class="text-2xl font-bold text-white mb-4">Już niebawem!</h1>

        <p class="text-gray-300 mb-6">Ta lekcja będzie odblokowana już wkrótce!</p>

        <div class="pt-4 border-t border-gray-700">
          <a href="https://przeprogramowani.pl" class="text-blue-400 hover:text-blue-300 text-sm underline">
            Przejdź na stronę główną Przeprogramowani.pl
          </a>
        </div>
      </div>
    </div>
  </div>
</SharedLessonLayout>
