---
import SharedLessonLayout from '@/layouts/SharedLessonLayout.astro';
---

<SharedLessonLayout title="Lekcja nie została znaleziona">
  <div class='min-h-screen flex items-center justify-center p-4'>
    <div class='max-w-md mx-auto text-center'>
      <div class='bg-gray-800 rounded-xl p-8 shadow-lg'>
        <div class='text-6xl mb-6'>🔍</div>
        
        <h1 class='text-2xl font-bold text-white mb-4'>
          Lekcja nie została znaleziona
        </h1>
        
        <p class='text-gray-300 mb-6'>
          Link, który próbujesz otworzyć, może być nieprawidłowy lub lekcja nie jest już dostępna.
        </p>
        
        <p class='text-gray-400 text-sm mb-6'>
          Skontaktuj się z autorami, lub mailem na 
          <a href="mailto:kontakt@przeprogramowani.pl" class='text-blue-400 hover:text-blue-300 underline'>
            kontakt@przeprogramowani.pl
          </a>
        </p>
        
        <div class='pt-4 border-t border-gray-700'>
          <a href="/courses" class='text-blue-400 hover:text-blue-300 text-sm underline'>
            Wróć do listy kursów
          </a>
        </div>
      </div>
    </div>
  </div>
</SharedLessonLayout>