{
  "name": "@przeprogramowani/edu-platform",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/edu-platform",
    "apps/10x-assistant",
    "apps/slides",
    "libs/circle"
  ],
  "scripts": {
    "prepare": "if [ \"$CF_PAGES\" != \"1\" ]; then husky install; fi",
    "format": "prettier -w .",
    "lint": "eslint . --ext .js,.ts,.astro,.svelte",
    "lint:fix": "npm run lint -- --fix",
    "dev:edu": "npm run dev --workspace=apps/edu-platform",
    "build:edu": "npm run build --workspace=apps/edu-platform",
    "10x:publish": "node apps/edu-platform/workbench/scripts/pipeline-full.mjs",
    "10x:publish:dry": "node apps/edu-platform/workbench/scripts/pipeline-full.mjs --dry-run",
    "10x:assets": "cd apps/edu-platform/workbench && npm run pipeline:assets",
    "10x:assets:dry": "cd apps/edu-platform/workbench && npm run pipeline:assets:dry",
    "10x:generate": "cd apps/edu-platform/workbench && npm run transport && cd ../../.. && npm run generate:lesson-html -w apps/edu-platform",
    "10x:check": "npm run check:lesson-html -w apps/edu-platform",
    "10x:prep": "npm run prep:lesson-html -w apps/edu-platform",
    "10x:i18n:export": "npm run copy:10xdevs3-prework:i18n -w apps/edu-platform",
    "10x:i18n:import": "npm run copy:10xdevs3-prework:en-from-i18n -w apps/edu-platform",
    "10x:i18n:enrich": "npm run enrich:lesson-html:en -w apps/edu-platform",
    "10x:i18n:repair": "npm run repair:prework-code-blocks -w apps/edu-platform",
    "10x:circle:backup": "cd tools/circle-lesson-backup && npm run start",
    "build:10x": "npm run build --workspace=apps/10x-assistant",
    "patch-cloudflare": "node tools/astro-patches/rewrite-deps.js",
    "patch-astro-datastore": "node tools/astro-patches/patch-content-datastore.js",
    "postinstall": "npm run patch-cloudflare && npm run patch-astro-datastore",
    "preinstall": "[ -n \"$GH_PKG_TOKEN\" ] && echo '//npm.pkg.github.com/:_authToken=${GH_PKG_TOKEN}' >> .npmrc || true",
    "test:edu": "npm run test --workspace=apps/edu-platform",
    "dev:10x": "npm run dev --workspace=apps/10x-assistant",
    "build:slides": "npm run build --workspace=apps/slides"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "12.2.0",
    "@astrojs/compiler": "^2.10.3",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/svelte": "7.0.4",
    "@astrojs/tailwind": "5.1.5",
    "@inox-tools/astro-when": "^1.0.1",
    "@mailerlite/mailerlite-nodejs": "^1.2.0",
    "@tailwindcss/forms": "^0.5.6",
    "astro": "5.1.8",
    "clipboardy": "^4.0.0",
    "cssesc": "^3.0.0",
    "dayjs": "^1.11.10",
    "es-toolkit": "^1.17.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "lucide-svelte": "0.462.0",
    "madge": "^8.0.0",
    "svelte": "^5.16.0",
    "svelte-youtube-lite": "^1.2.1",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@nx/playwright": "^22.7.1",
    "@tailwindcss/typography": "0.5.12",
    "@types/node": "20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-astro": "^0.29.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-svelte": "^2.34.1",
    "glob": "10.3.10",
    "husky": "^8.0.3",
    "jsdom": "24.1.1",
    "lint-staged": "^15.0.2",
    "nx": "22.7.1",
    "octokit": "3.1.2",
    "openai": "4.22.0",
    "prettier": "3.0.3",
    "prettier-plugin-astro": "0.12.1",
    "prettier-plugin-svelte": "^3.3.2",
    "sharp": "^0.33.5",
    "svgo": "^3.3.2",
    "tsx": "4.19.2",
    "vite-plugin-image-optimizer": "^1.1.8",
    "vitest": "^0.34.6",
    "dotenv": "17.2.3",
    "cheerio": "1.0.0",
    "turndown": "^7.2.1"
  },
  "engines": {
    "node": "22"
  }
}
