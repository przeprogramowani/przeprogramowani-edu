{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/package.json"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/tests/**/*",
      "!{projectRoot}/vitest.config.*",
      "!{projectRoot}/playwright.config.*"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build",
        "check"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    },
    "dev": {
      "cache": false
    },
    "test": {
      "inputs": [
        "default",
        "^production"
      ],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "check": {
      "inputs": [
        "default",
        "^default"
      ],
      "cache": true
    },
    "lint": {
      "inputs": [
        "default"
      ],
      "cache": true
    },
    "deploy": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "deploy:preview": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    }
  },
  "defaultBase": "master"
}